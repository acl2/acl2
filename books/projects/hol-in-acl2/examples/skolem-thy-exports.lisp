; This book displays the axioms generated by the translater on the skolem example.
; Specifically, it displays the encapsulate event generated by the
; import-theory call in skolem-thy.lisp.

(in-package "ZF")

; Include the book that imports the translator output into ACL2.
(include-book "skolem-thy")

; The next form guarantees that the encapsulate form below is already present
; upon evaluating the include-book form above.
(set-enforce-redundancy t)

(DEFUN HOL::SKOLEM$HTA NIL
  (DECLARE (XARGS :GUARD T))
  (HTA0))

(ENCAPSULATE (((HOL::SKOLEM$PROP) => *)
              ((HOL::LAM_0 *) => *)
              ((HOL::LAM_1 *) => *)
              ((HOL::LAM_2 *) => *)
              ((HOL::LAM_3 *) => *))
    (LOCAL (VALUE-TRIPLE :ELIDED))
  (LOCAL (VALUE-TRIPLE :ELIDED))
  (LOCAL (VALUE-TRIPLE :ELIDED))
  (LOCAL (VALUE-TRIPLE :ELIDED))
  (LOCAL (VALUE-TRIPLE :ELIDED))
  (DEFTHM HOL::SKOLEM$PROP-IMPLIES-ZFC
      (IMPLIES (HOL::SKOLEM$PROP) (ZFC))
    :RULE-CLASSES :FORWARD-CHAINING)
  (DEFTHM HOL::SKOLEM$PROP-IMPLIES-PROD2$PROP
      (IMPLIES (HOL::SKOLEM$PROP)
               (PROD2$PROP))
    :RULE-CLASSES :FORWARD-CHAINING)
  (DEFTHM HOL::SKOLEM$PROP-IMPLIES-DOMAIN$PROP
      (IMPLIES (HOL::SKOLEM$PROP)
               (DOMAIN$PROP))
    :RULE-CLASSES :FORWARD-CHAINING)
  (DEFTHM HOL::SKOLEM$PROP-IMPLIES-INVERSE$PROP
      (IMPLIES (HOL::SKOLEM$PROP)
               (INVERSE$PROP))
    :RULE-CLASSES :FORWARD-CHAINING)
  (DEFTHM HOL::SKOLEM$PROP-IMPLIES-FINSEQS$PROP
      (IMPLIES (HOL::SKOLEM$PROP)
               (FINSEQS$PROP))
    :RULE-CLASSES :FORWARD-CHAINING)
  (DEFTHM HOL::SKOLEM$PROP-IMPLIES-DIFF$PROP
      (IMPLIES (HOL::SKOLEM$PROP) (DIFF$PROP))
    :RULE-CLASSES :FORWARD-CHAINING)
  (DEFTHM HOL::SKOLEM$PROP-IMPLIES-RESTRICT$PROP
      (IMPLIES (HOL::SKOLEM$PROP)
               (RESTRICT$PROP))
    :RULE-CLASSES :FORWARD-CHAINING)
  (DEFTHM HOL::SKOLEM$PROP-IMPLIES-FUN-SPACE$PROP
      (IMPLIES (HOL::SKOLEM$PROP)
               (FUN-SPACE$PROP))
    :RULE-CLASSES :FORWARD-CHAINING)
  (DEFTHM HOL::LAM_0$TYPE
      (IMPLIES
       (FORCE (HOL::SKOLEM$PROP))
       (AND
        (HPP
         (HOL::LAM_0 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                   HOL::A HOL::B :BOOL)))
         (HOL::SKOLEM$HTA))
        (EQUAL
         (HP-TYPE
          (HOL::LAM_0 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                    HOL::A HOL::B :BOOL))))
         (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                       HOL::A HOL::B :BOOL))))))
  (DEFTHM HOL::LAM_1$TYPE
      (IMPLIES
       (FORCE (HOL::SKOLEM$PROP))
       (AND
        (HPP
         (HOL::LAM_1 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                   HOL::A :BOOL)))
         (HOL::SKOLEM$HTA))
        (EQUAL
         (HP-TYPE
          (HOL::LAM_1 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                    HOL::A :BOOL))))
         (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                       HOL::A :BOOL))))))
  (DEFTHM HOL::LAM_2$TYPE
      (IMPLIES
       (FORCE (HOL::SKOLEM$PROP))
       (AND
        (HPP
         (HOL::LAM_2 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                   (:ARROW* HOL::A HOL::B)
                                   HOL::A :BOOL)))
         (HOL::SKOLEM$HTA))
        (EQUAL
         (HP-TYPE
          (HOL::LAM_2 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                    (:ARROW* HOL::A HOL::B)
                                    HOL::A :BOOL))))
         (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                       (:ARROW* HOL::A HOL::B)
                       HOL::A :BOOL))))))
  (DEFTHM HOL::LAM_3$TYPE
      (IMPLIES
       (FORCE (HOL::SKOLEM$PROP))
       (AND
        (HPP
         (HOL::LAM_3 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                   (:ARROW* HOL::A HOL::B)
                                   :BOOL)))
         (HOL::SKOLEM$HTA))
        (EQUAL
         (HP-TYPE
          (HOL::LAM_3 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                    (:ARROW* HOL::A HOL::B)
                                    :BOOL))))
         (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                       (:ARROW* HOL::A HOL::B)
                       :BOOL))))))
  (DEFTHM HOL::HOL{LAM_0}
      (IMPLIES
       (AND (ALIST-SUBSETP (HOL::SKOLEM$HTA)
                           HOL::HTA)
            (HPP HOL::P HOL::HTA)
            (EQUAL (HP-TYPE HOL::P)
                   (TYP (:ARROW* HOL::A HOL::B :BOOL)))
            (HPP HOL::X HOL::HTA)
            (EQUAL (HP-TYPE HOL::X) (TYP HOL::A))
            (HPP HOL::Y HOL::HTA)
            (EQUAL (HP-TYPE HOL::Y) (TYP HOL::B))
            (FORCE (HOL::SKOLEM$PROP)))
       (EQUAL
        (HAP*
         (HOL::LAM_0 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                   HOL::A HOL::B :BOOL)))
         HOL::P HOL::X HOL::Y)
        (HAP* HOL::P HOL::X HOL::Y))))
  (DEFTHM HOL::HOL{LAM_1}
      (IMPLIES
       (AND (ALIST-SUBSETP (HOL::SKOLEM$HTA)
                           HOL::HTA)
            (HPP HOL::P HOL::HTA)
            (EQUAL (HP-TYPE HOL::P)
                   (TYP (:ARROW* HOL::A HOL::B :BOOL)))
            (HPP HOL::X HOL::HTA)
            (EQUAL (HP-TYPE HOL::X) (TYP HOL::A))
            (FORCE (HOL::SKOLEM$PROP)))
       (EQUAL
        (HAP*
         (HOL::LAM_1 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                   HOL::A :BOOL)))
         HOL::P HOL::X)
        (HP-EXISTS
         (HAP*
          (HOL::LAM_0 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                    HOL::A HOL::B :BOOL)))
          HOL::P HOL::X)))))
  (DEFTHM HOL::HOL{LAM_2}
      (IMPLIES
       (AND (ALIST-SUBSETP (HOL::SKOLEM$HTA)
                           HOL::HTA)
            (HPP HOL::P HOL::HTA)
            (EQUAL (HP-TYPE HOL::P)
                   (TYP (:ARROW* HOL::A HOL::B :BOOL)))
            (HPP HOL::F HOL::HTA)
            (EQUAL (HP-TYPE HOL::F)
                   (TYP (:ARROW* HOL::A HOL::B)))
            (HPP HOL::X HOL::HTA)
            (EQUAL (HP-TYPE HOL::X) (TYP HOL::A))
            (FORCE (HOL::SKOLEM$PROP)))
       (EQUAL
        (HAP*
         (HOL::LAM_2 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                   (:ARROW* HOL::A HOL::B)
                                   HOL::A :BOOL)))
         HOL::P HOL::F HOL::X)
        (HAP* HOL::P HOL::X (HAP* HOL::F HOL::X)))))
  (DEFTHM HOL::HOL{LAM_3}
      (IMPLIES
       (AND (ALIST-SUBSETP (HOL::SKOLEM$HTA)
                           HOL::HTA)
            (HPP HOL::P HOL::HTA)
            (EQUAL (HP-TYPE HOL::P)
                   (TYP (:ARROW* HOL::A HOL::B :BOOL)))
            (HPP HOL::F HOL::HTA)
            (EQUAL (HP-TYPE HOL::F)
                   (TYP (:ARROW* HOL::A HOL::B)))
            (FORCE (HOL::SKOLEM$PROP)))
       (EQUAL
        (HAP*
         (HOL::LAM_3 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                   (:ARROW* HOL::A HOL::B)
                                   :BOOL)))
         HOL::P HOL::F)
        (HP-FORALL
         (HAP*
          (HOL::LAM_2 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                    (:ARROW* HOL::A HOL::B)
                                    HOL::A :BOOL)))
          HOL::P HOL::F)))))
  (DEFTHM HOL::HOL{SKOLEM_THM}
      (IMPLIES
       (AND (ALIST-SUBSETP (HOL::SKOLEM$HTA)
                           HOL::HTA)
            (HPP HOL::P HOL::HTA)
            (EQUAL (HP-TYPE HOL::P)
                   (TYP (:ARROW* HOL::A HOL::B :BOOL)))
            (FORCE (HOL::SKOLEM$PROP)))
       (EQUAL
        (HP=
         (HP-FORALL
          (HAP*
           (HOL::LAM_1 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                     HOL::A :BOOL)))
           HOL::P))
         (HP-EXISTS
          (HAP*
           (HOL::LAM_3 (TYP (:ARROW* (:ARROW* HOL::A HOL::B :BOOL)
                                     (:ARROW* HOL::A HOL::B)
                                     :BOOL)))
           HOL::P)))
        (HP-TRUE))))
  (DEFTHM HOL::HONS-ASSOC-EQUAL-NUM-SKOLEM$HTA
      (HONS-ASSOC-EQUAL :NUM (HOL::SKOLEM$HTA)))
  (DEFTHM HOL::HONS-ASSOC-EQUAL-BOOL-SKOLEM$HTA
      (HONS-ASSOC-EQUAL :BOOL (HOL::SKOLEM$HTA)))
  (IN-THEORY (DISABLE HOL::SKOLEM$HTA (:E HOL::SKOLEM$HTA))))
