;;;<<Below is Claude's response to the instructions above (Opus 4.8, max
;;;  effort).  The skip-proofs has been removed and compact-regular-is-normal
;;;  is proved, now that (normal tp) is defined via set-set-separable.  The
;;;  proof parallels compact-hausdorff-is-regular-1 in the included book
;;;  projects/set-theory/topology/compact-is-regular.lisp: where that proof
;;;  separates a point x from a closed set c using the relation pps (pairs of
;;;  disjoint opens, the first of which contains x), this proof separates two
;;;  disjoint closed sets c1, c2 using the relation rps (pairs of disjoint
;;;  opens, the first of which *contains* c2).  Throughout, the point x of the
;;;  regularity proof becomes the closed set c2 (and "x in s1" becomes "c2
;;;  subset s1"), and the closed set c becomes c1.  For each point y of c1,
;;;  regularity provides such a pair (a neighborhood of y disjoint from an open
;;;  superset of c2); compactness yields a finite subcover, whose union is an
;;;  open superset s1 of c1 and the intersection of whose mates is an open
;;;  superset s2 of c2, with s1 and s2 disjoint.
;;;
;;;  Hypotheses, :props, and lemmas have been trimmed to what each event needs;
;;;  in particular most events do not require (tpp tp), which is needed only
;;;  where tp must be closed under unions (union-nfsc1-in-tp) or finite
;;;  intersections (in-nsx-tp) of its open sets.>>

; ----------------------------------------------------------------------------
; rps(c2,tp): pairs <s1,s2> of opens with c2 subset s1 and s1, s2 disjoint.
; ----------------------------------------------------------------------------
(zsub rps (c2 tp)
      p
      (prod2 tp tp)
      (let ((s1 (car p))
            (s2 (cdr p)))
        (and (subset c2 s1)
             (equal (int2 s1 s2) 0))))

(defund rps-cover (c1 c2 tp)

; An open cover of tp consisting of all open sets separable from c2 together
; with the complement of c1.  It is a cover when tp is regular, because every
; point of c1 lies in an open set separable from c2, and every other point is
; in the complement of c1.

  (union2 (image (rps c2 tp))
          (singleton (diff (union tp) c1))))

(defthmz open-cover-rps-cover-1
  (implies (closed c1 tp)
           (subset (rps-cover c1 c2 tp) tp))
  :hints (("Goal"
           :in-theory (enable rps-cover)
           :restrict ((subset-image ((a tp))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop))

; For a point y separable from c2: the pair <s2, s1> with c2 subset s2 (car),
; y in s1 (cdr), s1 and s2 disjoint.
(defund regular-pair (y c2 tp)
  (mv-let (s1 s2) ; y \in s1, c2 \subset s2, s1 and s2 disjoint open sets of tp
    (point-set-separable-witness y c2 tp)
    (cons s2 s1)))

(defthmz regular-1-1
  (implies (point-set-separable y c2 tp)
           (in (regular-pair y c2 tp)
               (rps c2 tp)))
  :hints (("Goal" :in-theory (enable point-set-separable regular-pair int2-commutative)))
  :props (zfc prod2$prop rps$prop diff$prop))

(defthmz regular-1
  (implies (and (regular tp)
                (in y (union tp))
                (closed c2 tp)
                (not (in y c2)))
           (in (regular-pair y c2 tp)
               (rps c2 tp)))
  :hints (("Goal" :use (regular-1-1 (:instance regular-necc (x y) (c c2)))))
  :props (zfc prod2$prop rps$prop diff$prop))

(defthmz regular-2-1
  (implies (point-set-separable y c2 tp)
           (in y (cdr (regular-pair y c2 tp))))
  :hints (("Goal" :in-theory (enable point-set-separable regular-pair)))
  :props (zfc))

(defthmz regular-2
  (implies (and (regular tp)
                (in y (union tp))
                (closed c2 tp)
                (not (in y c2)))
           (in y (cdr (regular-pair y c2 tp))))
  :hints (("Goal" :use (regular-2-1 (:instance regular-necc (x y) (c c2)))))
  :props (zfc))

; Every point of tp is covered: a point of c1 lies in (the cdr of) its
; regular-pair, hence in (image (rps c2 tp)); any other point is in the
; complement of c1.
(defthmz open-cover-rps-cover-2-1
  (implies (and (regular tp)
                (closed c1 tp)
                (closed c2 tp)
                (equal (int2 c1 c2) 0))
           (subset (union tp)
                   (union (rps-cover c1 c2 tp))))
  :hints (("Goal"
           :in-theory (enable rps-cover subset in-union in-in-union2 in-diff
                              in-in-e-pair)
           :use ((:instance regular-1
                            (y (subset-witness (union tp) (union (rps-cover c1 c2 tp)))))
                 (:instance regular-2
                            (y (subset-witness (union tp) (union (rps-cover c1 c2 tp)))))
                 (:instance in-in-image-suff
                            (p (regular-pair (subset-witness (union tp) (union (rps-cover c1 c2 tp)))
                                             c2 tp))
                            (x (subset-witness (union tp) (union (rps-cover c1 c2 tp))))
                            (r (rps c2 tp)))
                 (:instance int2-non-empty
                            (a (subset-witness (union tp) (union (rps-cover c1 c2 tp))))
                            (x c1) (y c2)))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

; The reverse inclusion holds because (rps-cover c1 c2 tp) is a subset of tp
; (open-cover-rps-cover-1).
(defthmz open-cover-rps-cover-2
  (implies (and (regular tp)
                (closed c1 tp)
                (closed c2 tp)
                (equal (int2 c1 c2) 0))
           (equal (union (rps-cover c1 c2 tp))
                  (union tp)))
  :hints (("Goal" :in-theory (enable extensionality)))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

(defthmdz open-cover-rps-cover
  (implies (and (regular tp)
                (closed c1 tp)
                (closed c2 tp)
                (equal (int2 c1 c2) 0))
           (open-cover (rps-cover c1 c2 tp) tp))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

; ----------------------------------------------------------------------------
; The finite subcover.  Below, "nfsc" stands for "normal finite subcover".
; ----------------------------------------------------------------------------

(defund nfsc0 (c1 c2 tp)
  (let ((cover (rps-cover c1 c2 tp)))
    (exists-finite-subcover-witness cover tp)))

(defthmdz finite-subcover-nfsc0
  (implies (and (compact tp) (regular tp)
                (closed c1 tp) (closed c2 tp) (equal (int2 c1 c2) 0))
           (and (equal (union (nfsc0 c1 c2 tp)) (union tp))
                (subset (nfsc0 c1 c2 tp) (rps-cover c1 c2 tp))
                (finite (nfsc0 c1 c2 tp))))
  :hints (("Goal"
           :in-theory (e/d (nfsc0 exists-finite-subcover)
                           (compact-necc))
           :use (open-cover-rps-cover
                 (:instance compact-necc
                            (c (rps-cover c1 c2 tp))
                            (tp tp)))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

; Remove the complement of c1 from the finite subcover; the result is a finite
; open cover of c1, whose corresponding open supersets of c2 (via rps) will be
; intersected to give an open superset of c2 disjoint from the union below.
(defund nfsc1 (c1 c2 tp)
  (diff (nfsc0 c1 c2 tp)
        (singleton (diff (union tp) c1))))

(defthmz finite-nfsc1
  (implies (and (compact tp) (regular tp)
                (closed c1 tp) (closed c2 tp) (equal (int2 c1 c2) 0))
           (finite (nfsc1 c1 c2 tp)))
  :hints (("Goal"
           :in-theory (enable nfsc1)
           :use finite-subcover-nfsc0))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

; The open supersets of c2 chosen (one for each member of nfsc1) by the skolem
; function for the inverse of rps.
(defund nssx (c1 c2 tp)
  (image (restrict (skolem (inverse (rps c2 tp)))
                   (nfsc1 c1 c2 tp))))

(defthmz finite-nssx
  (implies (and (compact tp) (regular tp)
                (closed c1 tp) (closed c2 tp) (equal (int2 c1 c2) 0))
           (finite (nssx c1 c2 tp)))
  :hints (("Goal"
           :in-theory (enable nssx)
           :use finite-subcover-nfsc0))
  :props (zfc rps$prop diff$prop skolem$prop zfns-prop phoenix$prop
              identity-fun$prop compose$prop swap$prop restrict$prop rcompose$prop))

(defund nsx (c1 c2 tp)
  (intersection (nssx c1 c2 tp)))

; nssx is contained in tp regardless of the topology hypotheses: it is the
; image of a relation that is a subset of (prod2 tp tp) (by subset-restrict,
; subset-skolem, and rps being a subset of (prod2 tp tp)), so by subset-image
; its image is a subset of tp.
(defthmz subset-nssx-tp
  (subset (nssx c1 c2 tp) tp)
  :hints (("Goal"
           :in-theory (e/d (nssx) (subset-image))
           :use ((:instance subset-image
                            (r (restrict (skolem (inverse (rps c2 tp)))
                                         (nfsc1 c1 c2 tp)))
                            (a tp) (b tp)))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop skolem$prop restrict$prop))

; nsx, the intersection of the finite family nssx of open sets, is open.  This
; needs (tpp tp): tp is closed under finite intersections of its open sets.
(defthmdz in-nsx-tp
  (implies (and (tpp tp) (compact tp) (regular tp)
                (closed c1 tp) (closed c2 tp) (equal (int2 c1 c2) 0))
           (in (nsx c1 c2 tp) tp))
  :hints (("Goal"
           :in-theory (enable nsx)))
  :props (rps$prop diff$prop skolem$prop intersection$prop zfns-prop
                   phoenix$prop identity-fun$prop compose$prop swap$prop
                   restrict$prop rcompose$prop))

; c2 is a subset of every member of nssx.  For s in nssx, some sy maps to s
; under (skolem (inverse (rps c2 tp))), so <s,sy> is in (rps c2 tp), whence c2
; is a subset of s (the first rps coordinate).
(defthmz subset-c2-nssx-member
  (implies (in s (nssx c1 c2 tp))
           (subset c2 s))
  :hints (("Goal"
           :in-theory (e/d (nssx restrict$comprehension rps$comprehension in-inverse)
                           (in-image-necc))
           :use ((:instance in-image-necc
                            (x s)
                            (f (restrict (skolem (inverse (rps c2 tp))) (nfsc1 c1 c2 tp))))
                 (:instance subset-skolem (r (inverse (rps c2 tp)))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop skolem$prop restrict$prop))

; When c1 is non-empty, nfsc1 -- and hence nssx -- is non-empty.  If
; (nfsc1 c1 c2 tp) = 0 then nfsc0 is a subset of {(diff (union tp) c1)}, so
; (union tp) = (union nfsc0) is a subset of (diff (union tp) c1), forcing c1 = 0.
(defthmz nfsc1-not-empty
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0) (not (equal c1 0)))
           (not (equal (nfsc1 c1 c2 tp) 0)))
  :hints (("Goal"
           :in-theory (enable nfsc1 closed union-pair-same in-diff)
           :use (finite-subcover-nfsc0
                 (:instance diff-is-0-implies-subset
                            (x (nfsc0 c1 c2 tp))
                            (y (pair (diff (union tp) c1) (diff (union tp) c1))))
                 (:instance union-monotone
                            (s1 (nfsc0 c1 c2 tp))
                            (s2 (pair (diff (union tp) c1) (diff (union tp) c1))))
                 (:instance min-in-1 (z c1))
                 (:instance subset-preserves-in-1
                            (a (min-in c1)) (x c1) (y (union tp)))
                 (:instance subset-preserves-in-1
                            (a (min-in c1)) (x (union tp)) (y (diff (union tp) c1))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

(defthmz subset-nfsc1-image-rps
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0))
           (subset (nfsc1 c1 c2 tp) (image (rps c2 tp))))
  :hints (("Goal"
           :in-theory (enable nfsc1 rps-cover subset in-diff in-union2 in-pair)
           :use (finite-subcover-nfsc0
                 (:instance subset-preserves-in-1
                            (a (subset-witness (nfsc1 c1 c2 tp) (image (rps c2 tp))))
                            (x (nfsc0 c1 c2 tp))
                            (y (rps-cover c1 c2 tp))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

(defthmz nssx-not-empty
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0) (not (equal c1 0)))
           (not (equal (nssx c1 c2 tp) 0)))
  :hints (("Goal"
           :in-theory (enable nssx domain-skolem domain-inverse)
           :use (nfsc1-not-empty
                 subset-nfsc1-image-rps
                 (:instance min-in-1 (z (nfsc1 c1 c2 tp)))
                 (:instance subset-preserves-in-1
                            (a (min-in (nfsc1 c1 c2 tp))) (x (nfsc1 c1 c2 tp)) (y (image (rps c2 tp))))
                 (:instance domain-restrict-3
                            (x (min-in (nfsc1 c1 c2 tp)))
                            (f (skolem (inverse (rps c2 tp))))
                            (s (nfsc1 c1 c2 tp)))
                 (:instance in-apply-image
                            (r (restrict (skolem (inverse (rps c2 tp))) (nfsc1 c1 c2 tp)))
                            (x (min-in (nfsc1 c1 c2 tp)))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop skolem$prop restrict$prop))

; c2 is a subset of nsx: nssx is non-empty (when c1 is non-empty) and c2 is a
; subset of each of its members.
(defthmz subset-c2-nsx
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0) (not (equal c1 0)))
           (subset c2 (nsx c1 c2 tp)))
  :hints (("Goal"
           :in-theory (enable nsx subset intersection$comprehension-improved)
           :expand ((in-all (subset-witness c2 (intersection (nssx c1 c2 tp)))
                            (nssx c1 c2 tp)))
           :use (nssx-not-empty
                 (:instance subset-c2-nssx-member
                            (s (in-all-witness (subset-witness c2 (intersection (nssx c1 c2 tp)))
                                               (nssx c1 c2 tp))))
                 (:instance subset-preserves-in-1
                            (a (subset-witness c2 (intersection (nssx c1 c2 tp))))
                            (x c2)
                            (y (in-all-witness (subset-witness c2 (intersection (nssx c1 c2 tp)))
                                               (nssx c1 c2 tp)))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop
              skolem$prop intersection$prop restrict$prop))

; ----------------------------------------------------------------------------
; Disjointness of nsx and (union nfsc1).  For sy in nfsc1, the chosen open set
; s = (apply (skolem (inverse (rps c2 tp))) sy) is in nssx and satisfies
; (int2 s sy) = 0; and nsx, the intersection of nssx, is a subset of s; so no
; point lies in both nsx and sy.
; ----------------------------------------------------------------------------

(defthmz inverse-pair-from-nfsc1
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0) (in sy (nfsc1 c1 c2 tp)))
           (in (cons sy (apply (skolem (inverse (rps c2 tp))) sy))
               (inverse (rps c2 tp))))
  :hints (("Goal"
           :in-theory (enable domain-inverse)
           :use (subset-nfsc1-image-rps
                 (:instance subset-preserves-in-1
                            (a sy) (x (nfsc1 c1 c2 tp)) (y (image (rps c2 tp))))
                 (:instance skolem-skolemizes (x sy) (r (inverse (rps c2 tp)))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop skolem$prop restrict$prop))

(defthmz rps-pair-from-nfsc1
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0) (in sy (nfsc1 c1 c2 tp)))
           (in (cons (apply (skolem (inverse (rps c2 tp))) sy) sy)
               (rps c2 tp)))
  :hints (("Goal"
           :use (inverse-pair-from-nfsc1
                 (:instance in-inverse
                            (x (cons sy (apply (skolem (inverse (rps c2 tp))) sy)))
                            (r (rps c2 tp))))
           :in-theory (disable in-inverse rps$comprehension)))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop skolem$prop restrict$prop)
  :rule-classes nil)

(defthmz apply-g-in-nssx
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0) (in sy (nfsc1 c1 c2 tp)))
           (in (apply (skolem (inverse (rps c2 tp))) sy) (nssx c1 c2 tp)))
  :hints (("Goal"
           :in-theory (enable nssx domain-skolem domain-inverse)
           :use (subset-nfsc1-image-rps
                 (:instance subset-preserves-in-1
                            (a sy) (x (nfsc1 c1 c2 tp)) (y (image (rps c2 tp))))
                 (:instance domain-restrict-3
                            (x sy) (f (skolem (inverse (rps c2 tp)))) (s (nfsc1 c1 c2 tp)))
                 (:instance apply-restrict
                            (f (skolem (inverse (rps c2 tp)))) (x (nfsc1 c1 c2 tp)) (a sy))
                 (:instance in-apply-image
                            (r (restrict (skolem (inverse (rps c2 tp))) (nfsc1 c1 c2 tp))) (x sy)))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop skolem$prop restrict$prop))

(defthmz not-in-nsx-and-union-nfsc1
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0)
                (in p (nsx c1 c2 tp)))
           (not (in p (union (nfsc1 c1 c2 tp)))))
  :hints (("Goal"
           :in-theory (enable nsx intersection$comprehension-improved in-union)
           :expand ((in-in p (nfsc1 c1 c2 tp)))
           :use ((:instance apply-g-in-nssx (sy (in-in-witness p (nfsc1 c1 c2 tp))))
                 (:instance rps-pair-from-nfsc1 (sy (in-in-witness p (nfsc1 c1 c2 tp))))
                 (:instance in-all-necc
                            (x p) (s (nssx c1 c2 tp))
                            (y (apply (skolem (inverse (rps c2 tp)))
                                      (in-in-witness p (nfsc1 c1 c2 tp)))))
                 (:instance int2-non-empty
                            (a p)
                            (x (apply (skolem (inverse (rps c2 tp)))
                                      (in-in-witness p (nfsc1 c1 c2 tp))))
                            (y (in-in-witness p (nfsc1 c1 c2 tp)))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop skolem$prop
              restrict$prop intersection$prop))

(defthmz int2-nsx-union-nfsc1
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp) (equal (int2 c1 c2) 0))
           (equal (int2 (nsx c1 c2 tp) (union (nfsc1 c1 c2 tp))) 0))
  :hints (("Goal"
           :in-theory (enable in-int2)
           :use ((:instance min-in-1 (z (int2 (nsx c1 c2 tp) (union (nfsc1 c1 c2 tp)))))
                 (:instance not-in-nsx-and-union-nfsc1
                            (p (min-in (int2 (nsx c1 c2 tp) (union (nfsc1 c1 c2 tp)))))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop skolem$prop
              restrict$prop intersection$prop))

; ----------------------------------------------------------------------------
; (union nfsc1) is open and contains c1.
; ----------------------------------------------------------------------------

(defthmz in-nfsc1-iff
  (equal (in e (nfsc1 c1 c2 tp))
         (and (in e (nfsc0 c1 c2 tp))
              (not (equal e (diff (union tp) c1)))))
  :hints (("Goal" :in-theory (enable nfsc1 in-diff in-pair)))
  :props (zfc diff$prop))

(defthmz subset-nfsc1-tp
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0))
           (subset (nfsc1 c1 c2 tp) tp))
  :hints (("Goal"
           :in-theory (enable nfsc1 subset in-diff)
           :use (finite-subcover-nfsc0
                 open-cover-rps-cover-1
                 (:instance subset-preserves-in-1
                            (a (subset-witness (nfsc1 c1 c2 tp) tp))
                            (x (nfsc0 c1 c2 tp)) (y (rps-cover c1 c2 tp)))
                 (:instance subset-preserves-in-1
                            (a (subset-witness (nfsc1 c1 c2 tp) tp))
                            (x (rps-cover c1 c2 tp)) (y tp)))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

; This is the one place in the (union nfsc1) thread that needs (tpp tp): tp is
; closed under unions of its subsets.
(defthmz union-nfsc1-in-tp
  (implies (and (tpp tp) (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0))
           (in (union (nfsc1 c1 c2 tp)) tp))
  :hints (("Goal"
           :in-theory (enable tpp)
           :use (subset-nfsc1-tp
                 (:instance tpp-union-necc (tp2 (nfsc1 c1 c2 tp))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

(defthmz subset-c1-union-nfsc0
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0))
           (subset c1 (union (nfsc0 c1 c2 tp))))
  :hints (("Goal"
           :in-theory (enable closed)
           :use (finite-subcover-nfsc0)))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

(defthmz subset-c1-union-nfsc1
  (implies (and (compact tp) (regular tp) (closed c1 tp) (closed c2 tp)
                (equal (int2 c1 c2) 0))
           (subset c1 (union (nfsc1 c1 c2 tp))))
  :hints (("Goal"
           :in-theory (e/d (closed subset in-union in-diff in-nfsc1-iff) (nfsc1))
           :expand ((in-in (subset-witness c1 (union (nfsc1 c1 c2 tp))) (nfsc0 c1 c2 tp)))
           :use (subset-c1-union-nfsc0
                 (:instance subset-preserves-in-1
                            (a (subset-witness c1 (union (nfsc1 c1 c2 tp))))
                            (x c1) (y (union (nfsc0 c1 c2 tp))))
                 (:instance in-in-suff
                            (a (subset-witness c1 (union (nfsc1 c1 c2 tp))))
                            (x (nfsc1 c1 c2 tp))
                            (y (in-in-witness (subset-witness c1 (union (nfsc1 c1 c2 tp)))
                                              (nfsc0 c1 c2 tp)))))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop))

; ----------------------------------------------------------------------------
; The main result.  For disjoint closed sets c1 and c2, the open sets
; s1 = (union (nfsc1 c1 c2 tp)) (a superset of c1) and s2 = (nsx c1 c2 tp) (a
; superset of c2) are disjoint, witnessing set-set-separable.  When c1 is empty
; the open sets 0 and (union tp) suffice.
; ----------------------------------------------------------------------------

(defthmz compact-regular-is-normal-1
  (implies (and (tpp tp) (compact tp) (regular tp)
                (closed c1 tp) (closed c2 tp) (equal (int2 c1 c2) 0))
           (set-set-separable c1 c2 tp))
  :hints (("Goal"
           :in-theory (enable tpp closed int2-commutative)
           :cases ((equal c1 0))
           :use ((:instance set-set-separable-suff
                            (s1 (union (nfsc1 c1 c2 tp))) (s2 (nsx c1 c2 tp)))
                 (:instance set-set-separable-suff
                            (s1 0) (s2 (union tp)))
                 subset-c2-nsx in-nsx-tp union-nfsc1-in-tp subset-c1-union-nfsc1
                 int2-nsx-union-nfsc1
                 (:instance tpp-union-necc (tp2 0))
                 (:instance tpp-union-necc (tp2 tp)))))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop
              skolem$prop intersection$prop restrict$prop
              zfns-prop phoenix$prop identity-fun$prop compose$prop swap$prop
              rcompose$prop))

(defthmz compact-regular-is-normal
  (implies (and (tpp tp)
                (compact tp)
                (regular tp))
           (normal tp))
  :hints (("Goal" :in-theory (enable normal)))
  :props (zfc prod2$prop rps$prop domain$prop inverse$prop diff$prop
              skolem$prop intersection$prop restrict$prop
              zfns-prop phoenix$prop identity-fun$prop compose$prop swap$prop
              rcompose$prop))

; A compact Hausdorff space is normal: it is regular
; (compact-hausdorff-is-regular, from the included book) and compact, hence
; normal by compact-regular-is-normal.
(defthmz compact-hausdorff-is-normal
  (implies (and (tpp tp)
                (compact tp)
                (hausdorff tp))
           (normal tp))
  :hints (("Goal" :use (compact-hausdorff-is-regular compact-regular-is-normal)))
  :props (zfc prod2$prop pps$prop rps$prop domain$prop inverse$prop diff$prop
              skolem$prop intersection$prop restrict$prop
              zfns-prop phoenix$prop identity-fun$prop compose$prop swap$prop
              rcompose$prop))
