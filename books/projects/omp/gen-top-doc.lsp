;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; Generator script for top-doc.lisp.
;
; Setup:
;   Make sure ACL2(r) is installed.
;   cd projects/omp
;   cert.pl top
;   Start ACL2(r)
;
; Usage:
;
;   OMP(r) !> (ld "gen-top-doc.lsp")
;
; This reads the current xdoc table, filters to OMP-defined topics, and
; writes them to `top-doc.lisp' as a sequence of (defxdoc ...) events with
; cert_param: (non-acl2r).  The central manual (acl2/books/doc/top.lisp)
; can then include top-doc.lisp to surface OMP topics, even though the
; underlying proofs require ACL2(r).
;
; Regenerate top-doc.lisp after any xdoc change in this directory.

(in-package "OMP")

(include-book "top")
(include-book "xdoc/top" :dir :system)

;; Trust tag for the file-I/O calls below; the resulting top-doc.lisp is a
;; plain-data artifact and contains no ttag.
(defttag :gen-top-doc)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Filter and ordering.

(defun omp-topic-p (topic)
  (declare (xargs :mode :program))
  ;; Filter by package: all our topic names live in "OMP".
  (let ((name (cdr (assoc :name topic))))
    (and (symbolp name)
         (acl2::equal (acl2::symbol-package-name name) "OMP"))))

(defun keep-omp-topics (topics)
  (declare (xargs :mode :program))
  (cond ((endp topics) nil)
        ((omp-topic-p (car topics))
         (cons (car topics) (keep-omp-topics (cdr topics))))
        (t (keep-omp-topics (cdr topics)))))

(defun topic< (t1 t2)
  (declare (xargs :mode :program))
  (acl2::string< (symbol-name (cdr (assoc :name t1)))
                 (symbol-name (cdr (assoc :name t2)))))

(defun insert-topic (topic sorted)
  (declare (xargs :mode :program))
  (cond ((endp sorted) (list topic))
        ((topic< topic (car sorted)) (cons topic sorted))
        (t (cons (car sorted) (insert-topic topic (cdr sorted))))))

(defun sort-topics (topics)
  (declare (xargs :mode :program))
  (cond ((endp topics) nil)
        (t (insert-topic (car topics) (sort-topics (cdr topics))))))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Output.

(defconst *header*
  "; AUTOGENERATED by (ld \"gen-top-doc.lsp\"); DO NOT EDIT.
;
; This file is loaded under standard ACL2 (e.g. by acl2/books/doc/top.lisp)
; so that the OMP xdoc topics appear in the central manual, even though
; the underlying proofs require ACL2(r).  Regenerate by LD'ing
; gen-top-doc.lsp from this directory under ACL2(r) after any xdoc change.

; cert_param: (non-acl2r)

(in-package \"OMP\")

(include-book \"xdoc/top\" :dir :system)

")

(defun write-topic (topic chan state)
  (declare (xargs :mode :program :stobjs state))
  (mv-let (col state)
    (acl2::fmt1!
     "(defxdoc ~x0~%  :parents ~x1~%  :short ~x2~%  :long ~x3)~%~%"
     (list (cons #\0 (cdr (assoc :name    topic)))
           (cons #\1 (cdr (assoc :parents topic)))
           (cons #\2 (cdr (assoc :short   topic)))
           (cons #\3 (cdr (assoc :long    topic))))
     0 chan state nil)
    (declare (ignore col))
    state))

(defun write-topics (topics chan state)
  (declare (xargs :mode :program :stobjs state))
  (cond ((endp topics) state)
        (t (let ((state (write-topic (car topics) chan state)))
             (write-topics (cdr topics) chan state)))))

(defun generate-top-doc (state)
  (declare (xargs :mode :program :stobjs state))
  (mv-let (chan state)
    (acl2::open-output-channel! "top-doc.lisp" :character state)
    (cond
     ((null chan)
      (mv "Could not open top-doc.lisp for writing." :error state))
     (t
      (let* ((state (acl2::princ$ *header* chan state))
             (all   (xdoc::get-xdoc-table (w state)))
             (ours  (sort-topics (keep-omp-topics all)))
             (state (write-topics ours chan state))
             (state (acl2::close-output-channel chan state)))
        (mv nil :ok state))))))

;; Run the generator.  Print-control globals are widened so that long
;; :long strings round-trip through `~x0' without truncation.
(make-event
 (acl2::state-global-let*
  ((acl2::print-length nil)
   (acl2::print-level nil)
   (acl2::print-lines nil))
  (er-progn (generate-top-doc state)
            (acl2::value '(value-triple "top-doc.lisp written.")))))
