;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; See [books]/kestrel/c/syntax/grammar.lisp for background.

; This file contains grammar rules for string literals in the C23 dialects
; [C23:6.4.6].
; The rules are the same as for C17,
; but we omit the rule for 'encoding-prefix' here,
; because it is already with the rules for character constants.

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

string-literal =
    [ encoding-prefix ] double-quote [ s-char-sequence ] double-quote

s-char-sequence = s-char
                / s-char-sequence s-char

s-char = character-not-double-quote-or-backslash-or-new-line
       / escape-sequence
