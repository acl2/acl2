;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; See [books]/kestrel/c/syntax/grammar.lisp for background.

; This file contains rules for constants for the C23 dialects [C23:6.4.5.1].
; We also include the predefined constants here [C23:6.4.5.6].

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

constant = integer-constant
         / floating-constant
         / enumeration-constant
         / character-constant
         / predefined-constant

predefined-constant = %s"false"
                    / %s"true"
                    / %s"nullptr"
