;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; See [books]/kestrel/c/syntax/grammar.lisp for background.

; This file contains grammar rules for floating constants [C17:6.4.4.2/1]
; that are specific to the C17 dialects with GCC extensions.
; Together with the generic rules in floating-constants.abnf
; and with the additional specialized rules in floating-constants-c17.abnf,
; they form the rules for floating constants of
; the C17 dialect with GCC extensions.

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; GCC adds floating suffixes for
; the additional floating types of size 16, 32, 64, and 128
; (https://gcc.gnu.org/onlinedocs/gcc/Floating-Types.html).

floating-suffix = %i"f"
                / %i"l"
                / %i"f" ( "16" / "32" / "64" / "128" ) %s"x"
