;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defsection pfcs-byte-lifting
  :short "Lifting of the byte constraints to a predicate."

  ;; The proofs generated by the following take too long,
  ;; so we lift manually below.
  ;; (pfcs::lift (pfcs-byte)
  ;;             :pred pfcs-byte-pred
  ;;             :prime prime)

  (defund-sk pfcs-byte-pred (x prime)
    (declare (ignorable x prime))
    (exists (x0 x1 x2 x3 x4 x5 x6 x7)
            (and
             (pfield::fep x0 prime)
             (pfield::fep x1 prime)
             (pfield::fep x2 prime)
             (pfield::fep x3 prime)
             (pfield::fep x4 prime)
             (pfield::fep x5 prime)
             (pfield::fep x6 prime)
             (pfield::fep x7 prime)
             (and
              (pfcs-bit-pred x0 prime)
              (pfcs-bit-pred x1 prime)
              (pfcs-bit-pred x2 prime)
              (pfcs-bit-pred x3 prime)
              (pfcs-bit-pred x4 prime)
              (pfcs-bit-pred x5 prime)
              (pfcs-bit-pred x6 prime)
              (pfcs-bit-pred x7 prime)
              (equal
               (pfield::sub
                (pfield::add
                 (pfield::add
                  (pfield::add
                   (pfield::add
                    (pfield::add
                     (pfield::add
                      (pfield::add
                       x0
                       (pfield::mul x1 (mod 2 prime) prime)
                       prime)
                      (pfield::mul x2 (mod 4 prime) prime)
                      prime)
                     (pfield::mul x3 (mod 8 prime) prime)
                     prime)
                    (pfield::mul x4 (mod 16 prime) prime)
                    prime)
                   (pfield::mul x5 (mod 32 prime) prime)
                   prime)
                  (pfield::mul x6 (mod 64 prime) prime)
                  prime)
                 (pfield::mul x7 (mod 128 prime) prime)
                 prime)
                x prime)
               (mod 0 prime))))))

  ;; TODO: lifting theorem
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defsection pfcs-all-transitions-lifting
  :short "Lifting of the constraints for all transitions to a predicate."

  (defund pfcs-all-transitions-pred (pcs ; pfield::fe-listp
                                     accs ; pfield::fe-listp
                                     ops ; pfield::fe-listp
                                     hlts ;  pfield::fe-listp
                                     prime) ; pfcs::primep
    ;; (len pcs) = (len accs) = (len ops) = (len hlts)
    (or (endp pcs)
        (endp (cdr pcs))
        (and (pfcs-transition-pred
              (car pcs) (car accs) (car ops) (car hlts)
              (cadr pcs) (cadr accs) (cadr ops) (cadr hlts)
              prime)
             (pfcs-all-transitions-pred (cdr pcs)
                                        (cdr accs)
                                        (cdr ops)
                                        (cdr hlts)
                                        prime))))

  ;; TODO: lifting theorem
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defsection pfcs-execution-lifting
  :short "Lifting of the constraints for execution."

  (defund pfcs-execution-pred (pcs ; pfield::fe-listp
                               accs ; pfield::fe-listp
                               ops ; pfield::fe-listp
                               hlts ;  pfield::fe-listp
                               prime) ; pfcs::primep
    ;; (len pcs) = (len accs) = (len ops) = (len hlts)
    (and (pfcs-initial-pred (car pcs)
                            (car accs)
                            (car ops)
                            (car hlts)
                            prime)
         (pfcs-all-transitions-pred pcs accs ops hlts prime)
         (pfcs-final-pred (car (last pcs))
                          (car (last accs))
                          (car (last ops))
                          (car (last hlts))
                          prime)))

  ;; TODO: lifting theorem
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defsection pfcs-path-lifting
  :short "Lifting of the path constraints to a predicate."

  (defund pfcs-path-pred (path ; nat-listp
                          pcs ; pfield::fe-listp
                          prime) ; pfcs::primep
    ;; (len pcs) = (len path)
    (or (endp path)
        (and (equal (pfield::sub (car pcs)
                                 (car path)
                                 prime)
                    0)
             (pfcs-path-pred (cdr path) (cdr pcs) prime))))

  ;; TODO: lifting theorem
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defsection pfcs-opcodes-lifting
  :short "Lifting of the opcode constraints to a predicate."

  (defund pfcs-opcodes-pred (opcodes ; program-p
                             ops ; pfield::fe-listp
                             prime) ; pfcs::primep
    ;; (len ops) = (len opcodes)
    (or (endp opcodes)
        (and (equal (pfield::sub (car ops)
                                 (opcode-to-field (car opcodes))
                                 prime)
                    0)
             (pfcs-opcodes-pred (cdr opcodes) (cdr ops) prime))))

  ;; TODO: lifting theorem
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defsection pfcs-accumulators-lifting
  :short "Lifting of the accumulator constraints to a predicate."

  (defund pfcs-accumulators-pred (accs ; pfield::fe-listp
                                  prime)
    (or (endp accs)
        (and (pfcs-byte-pred (car accs) prime)
             (pfcs-accumulators-pred (cdr accs) prime))))

  ;; TODO: lifting theorem

)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defsection pfcs-table-lifting
  :short "Lifting of the table constraints to a predicate."

  (defund pfcs-table-pred (path ; nat-listp
                           opcodes ; program-p
                           pcs ; pfield::fe-listp
                           accs ; pfield::fe-listp
                           ops ; pfield::fe-listp
                           hlts ;  pfield::fe-listp
                           prime) ; pfcs::primep
    ;; (len pcs) = (len accs) = (len ops) = (len hlts) = (len opcodes)
    (and (pfcs-execution-pred pcs accs ops hlts prime)
         (pfcs-path-pred path pcs prime)
         (pfcs-opcodes-pred opcodes ops prime)
         (pfcs-accumulators-pred accs prime)))

  ;; TODO: lifting theorem
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defsection pfcs-computation-lifting
  :short "Lifting of the computation constraints to a predicate."

  (defund-sk pfcs-computation-pred (path ; nat-listp
                                    opcodes ; program-p
                                    input ; pfield::fe-listp
                                    output ; pfield::fe-listp
                                    prime) ; pfcs::primep
    ;; (len opcodes) = (len path)
    (exists (pcs accs ops hlts)
            (and (pfield::fe-listp pcs prime)
                 (pfield::fe-listp accs prime)
                 (pfield::fe-listp ops prime)
                 (pfield::fe-listp hlts prime)
                 (equal (len pcs) (len opcodes))
                 (equal (len accs) (len opcodes))
                 (equal (len ops) (len opcodes))
                 (equal (len hlts) (len opcodes))
                 (pfcs-table-pred path opcodes pcs accs ops hlts prime)
                 (equal input (car accs))
                 (equal output (car (last accs))))))

  ;; TODO: lifting theorem
)
