(defxdoc+ identifier-syntax
  :parents (concrete-syntax)
  :short "Syntactic constraints on Remora identifiers."
  :long
  (xdoc::topstring
   (xdoc::p
    "The Remora grammar's @('identifier') rule plus its side condition
     [SC2] together impose constraints on the text of an identifier:
     leading and continuation code points must come from specific
     character classes, and the resulting text must not match a
     reserved keyword.  This file collects those constraints in three
     categories, so that downstream consumers can use them without
     pulling in the parser.")
   (xdoc::p
    (xdoc::b "Code-point class predicates."))
   (xdoc::ul
    (xdoc::li
     "@(tsee non-asciip) &mdash; non-ASCII non-whitespace non-surrogate
      code point.")
    (xdoc::li
     "@(tsee id-startp) &mdash; valid identifier start code point
      (mirrors the @('id-start') ABNF rule).")
    (xdoc::li
     "@(tsee id-continuep) &mdash; valid identifier continuation code
      point (mirrors @('id-continue'); strict superset of
      @(tsee id-startp), adding digits).")
    (xdoc::li
     "@(tsee id-continue-list-p) &mdash; list extension of
      @(tsee id-continuep): every code point in the list passes."))
   (xdoc::p
    (xdoc::b "Keyword exclusion."))
   (xdoc::ul
    (xdoc::li
     "@(tsee *remora-keywords-as-natlists*) &mdash; the list of
      reserved keywords as code-point sequences.  Single-character
      Unicode keywords (lambda, arrow, forall, etc.) appear as
      one-element lists.")
    (xdoc::li
     "@(tsee remora-keyword-p) &mdash; membership predicate."))
   (xdoc::p
    (xdoc::b "Identifier validators."))
   (xdoc::ul
    (xdoc::li
     "@(tsee valid-identifier-codepoints-p) &mdash; checks a code-point
      list: non-empty, first is @(tsee id-startp), rest are
      @(tsee id-continuep), and the whole sequence is not a keyword.")
    (xdoc::li
     "@(tsee valid-identifier-string-p) &mdash; the user-facing
      string predicate: UTF-8 decodes to a list satisfying
      @(tsee valid-identifier-codepoints-p)."))
   (xdoc::p
    "Consumers within Remora:")
   (xdoc::ul
    (xdoc::li
     "@(tsee parser) consults @(tsee id-startp) and @(tsee id-continuep)
      when parsing the @('identifier') ABNF rule.")
    (xdoc::li
     "@(tsee post-parsing) consults @(tsee *remora-keywords-as-natlists*)
      and @(tsee remora-keyword-p) when walking a CST to enforce
      [SC2].")
    (xdoc::li
     "The AST-level well-formedness predicates @('xxx-wf-ast-p') consult
      @(tsee valid-identifier-string-p) on the identifiers stored inside
      AST nodes.  For example, @(tsee bind-wf-ast-p).  For the whole program,
      @(tsee prog-wf-ast-p).")))
  :order-subtopics t
  :default-parent t)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
;; Code-point class predicates.
;;
;; non-asciip, id-startp, and id-continuep mirror the corresponding
;; rules of grammar.abnf.  They are hand-written rather than
;; auto-generated because each rule has 9-13 range alternatives, which
;; cause combinatorial proof blowup when generated by ABNF tooling.
;; id-continue-list-p is a small list extension of id-continuep.
;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define non-asciip ((nat natp))
  :returns (yes/no booleanp)
  :short "Check if a natural number is a non-ASCII non-whitespace
          non-surrogate code point."
  :long
  (xdoc::topstring
   (xdoc::p
    "Mirrors the @('non-ascii') rule of @('grammar.abnf'), which lists
     the Unicode ranges outside ASCII (above @('#x7F')) that are
     not whitespace per Haskell's @('Data.Char.isSpace') and are not
     surrogates."))
  (b* ((nat (nfix nat)))
    (or (and (<= #x80 nat) (<= nat #x9F))
        (and (<= #xA1 nat) (<= nat #x167F))
        (and (<= #x1681 nat) (<= nat #x1FFF))
        (and (<= #x200B nat) (<= nat #x2027))
        (and (<= #x202A nat) (<= nat #x202E))
        (and (<= #x2030 nat) (<= nat #x205E))
        (and (<= #x2060 nat) (<= nat #x2FFF))
        (and (<= #x3001 nat) (<= nat #xD7FF))
        (and (<= #xE000 nat) (<= nat #x10FFFF)))))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define id-startp ((nat natp))
  :returns (yes/no booleanp)
  :short "Check if a natural number is a valid identifier start code point."
  :long
  (xdoc::topstring
   (xdoc::p
    "Mirrors the @('id-start') rule of @('grammar.abnf').  The ASCII
     ranges below are the complement of the disallowed characters
     (whitespace and @('( ) [ ] @{ @} \" , ' ` ; # | \\\\ @@'),
     plus digits, which are excluded only at the start) within the
     printable ASCII range @('#x21')&ndash;@('#x7E').  Plus C0 control
     characters except whitespace (@('#x00')&ndash;@('#x08'),
     @('#x0E')&ndash;@('#x1F')) and DEL (@('#x7F')), and the
     @(tsee non-asciip) range."))
  (b* ((nat (nfix nat)))
    (or (and (<= #x00 nat) (<= nat #x08))
        (and (<= #x0E nat) (<= nat #x1F))
        (eql nat #x21)
        (and (<= #x24 nat) (<= nat #x26))
        (and (<= #x2A nat) (<= nat #x2B))
        (and (<= #x2D nat) (<= nat #x2F))
        (eql nat #x3A)
        (and (<= #x3C nat) (<= nat #x3F))
        (and (<= #x41 nat) (<= nat #x5A))
        (and (<= #x5E nat) (<= nat #x5F))
        (and (<= #x61 nat) (<= nat #x7A))
        (and (<= #x7E nat) (<= nat #x7F))
        (non-asciip nat))))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define id-continuep ((nat natp))
  :returns (yes/no booleanp)
  :short "Check if a natural number is a valid identifier continuation
          code point."
  :long
  (xdoc::topstring
   (xdoc::p
    "Mirrors the @('id-continue') rule of @('grammar.abnf').  The same
     classes as @(tsee id-startp), augmented with the digit range
     @('#x30')&ndash;@('#x39') (folded into the range
     @('#x2D')&ndash;@('#x3A')).  Digits are valid in identifier
     positions other than the first."))
  (b* ((nat (nfix nat)))
    (or (and (<= #x00 nat) (<= nat #x08))
        (and (<= #x0E nat) (<= nat #x1F))
        (eql nat #x21)
        (and (<= #x24 nat) (<= nat #x26))
        (and (<= #x2A nat) (<= nat #x2B))
        (and (<= #x2D nat) (<= nat #x3A))   ; includes digits and :
        (and (<= #x3C nat) (<= nat #x3F))
        (and (<= #x41 nat) (<= nat #x5A))
        (and (<= #x5E nat) (<= nat #x5F))
        (and (<= #x61 nat) (<= nat #x7A))
        (and (<= #x7E nat) (<= nat #x7F))
        (non-asciip nat))))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define id-continue-list-p ((nats nat-listp))
  :returns (yes/no booleanp)
  :short "Check that every code point in a list satisfies @(tsee id-continuep)."
  (cond ((endp nats) t)
        ((not (id-continuep (car nats))) nil)
        (t (id-continue-list-p (cdr nats)))))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defsection identifier-character-classes-relations
  :short "Relationships among the identifier character-class predicates."
  :long
  (xdoc::topstring
   (xdoc::p
    "An @('id-start') code point is also an @('id-continue') code
     point: the @('id-continue') class is a strict superset of
     @('id-start') (it adds the digits @('#x30')&ndash;@('#x39'))."))

  (defrule id-continuep-when-id-startp
    (implies (id-startp nat)
             (id-continuep nat))
    :enable (id-startp id-continuep)))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
;; Reserved keyword list (side condition [SC2]).
;;
;; The grammar's identifier rule accepts any
;; id-start *id-continue sequence, including reserved keywords.
;; The keyword list below names the strings that may not be used as
;; identifier values.  Single-character Unicode keywords (lambda,
;; arrow, forall, etc.) are encoded by their code point directly
;; rather than via string=>nats, since the latter only handles
;; char-codes 0-255.
;;
;; This list is consulted both by the CST-level walk
;; check-tree-no-keyword-identifiers (xdoc topic post-parsing) and
;; (planned) by the AST-level identifier validator.
;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defval *remora-keywords-as-natlists*
  :short "List of Remora reserved keywords, as code-point sequences."
  :long
  (xdoc::topstring
   (xdoc::p
    "Each element is a list of @(tsee natp) Unicode code points, one
     per character of the keyword.  Single-character Unicode keywords
     (lambda U+03BB, t-lambda, i-lambda, rightwards arrow U+2192,
     forall U+2200, capital Pi U+03A0, capital Sigma U+03A3) appear
     by their code point directly rather than via @(tsee
     string=>nats), since the latter only handles char-codes
     0&ndash;255.  ASCII-only keywords use @(tsee string=>nats)
     for readability.")
   (xdoc::p
    "Side condition [SC2] of the grammar (see @('grammar.abnf')) says
     that no identifier may match a reserved keyword.  This list
     drives the membership predicate @(tsee remora-keyword-p) used by
     both the CST-level walk @(tsee check-tree-no-keyword-identifiers)
     and the AST-level @(tsee valid-identifier-codepoints-p)."))
  (list (string=>nats "array")
        (string=>nats "frame")
        (string=>nats "t-app")
        (string=>nats "i-app")
        (string=>nats "unbox")
        (string=>nats "box")
        (string=>nats "dims")
        (string=>nats "fn")
        (list #x03BB)            ; lambda
        (string=>nats "t-fn")
        (list (char-code #\t) #x03BB)  ; t + lambda
        (string=>nats "i-fn")
        (list (char-code #\i) #x03BB)  ; i + lambda
        (string=>nats "A")
        (string=>nats "->")
        (list #x2192)            ; rightwards arrow
        (string=>nats "Forall")
        (list #x2200)            ; for all
        (string=>nats "Pi")
        (list #x03A0)            ; Greek capital letter Pi
        (string=>nats "Sigma")
        (list #x03A3)            ; Greek capital letter Sigma
        (string=>nats "let")
        (string=>nats "type")
        (string=>nats "ispace")
        (string=>nats "fun")
        (string=>nats "t-fun")
        (string=>nats "i-fun")
        (string=>nats "val")))

(define remora-keyword-p (nats)
  :returns (yes/no booleanp)
  :short "Check if a list of code points matches a Remora keyword."
  (if (member-equal nats *remora-keywords-as-natlists*) t nil))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
;; Identifier validators.
;;
;; valid-identifier-codepoints-p answers yes/no over a list of code
;; points; valid-identifier-string-p answers yes/no over an ACL2
;; string (decoding UTF-8 first).  The string-level predicate is the
;; user-facing entry point; the codepoint-level one is useful when
;; callers have already done UTF-8 decoding (e.g., during CST-to-AST
;; abstraction, where the parser has produced a code-point list before
;; the abstractor re-encodes the identifier as UTF-8 bytes for storage
;; in an ACL2 string).
;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define valid-identifier-codepoints-p ((codepoints nat-listp))
  :returns (yes/no booleanp)
  :short "Check that a list of code points forms a valid Remora identifier."
  :long
  (xdoc::topstring
   (xdoc::p
    "The list must be non-empty.  Its first element must satisfy
     @(tsee id-startp), and all remaining elements must satisfy
     @(tsee id-continuep).  Finally, the list itself, viewed as a
     code-point sequence, must not match any reserved keyword
     in @(tsee *remora-keywords-as-natlists*) (side condition [SC2]
     in @('grammar.abnf'))."))
  (and (consp codepoints)
       (id-startp (car codepoints))
       (id-continue-list-p (cdr codepoints))
       (not (remora-keyword-p codepoints))))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define valid-identifier-string-p ((str stringp))
  :returns (yes/no booleanp)
  :hooks nil
  :short "Check that an ACL2 string is a valid Remora identifier."
  :long
  (xdoc::topstring
   (xdoc::p
    "Treats @('str') as a sequence of UTF-8 bytes (ACL2 strings have
     char-codes 0&ndash;255), decodes it to a Unicode code-point
     sequence, and applies @(tsee valid-identifier-codepoints-p) to
     the result.  Returns @('nil') if the byte sequence is not valid
     UTF-8 or if any of the code-point-level checks fail."))
  (b* ((bytes (string=>nats (str-fix str)))
       ((unless (acl2::unsigned-byte-listp 8 bytes)) nil)
       (codepoints (acl2::utf8=>ustring bytes))
       ((unless (nat-listp codepoints)) nil))
    (valid-identifier-codepoints-p codepoints)))
