; =========================================================================
; ABNF Grammar for the Remora Programming Language
; (remora-lang/remora -- Haskell implementation)
;
; Derived from src/Parser.hs, src/Syntax.hs, src/Shape.hs,
; and docs/language.rst
;
; For reference see also "The Semantics of Rank Polymorphism"
; https://arxiv.org/abs/1907.00509v1 (mentioned below as "the paper").
;
; The input is assumed to be a sequence of valid Unicode characters
; not including surrogates, as represented by the natural numbers
; in ( %x00-D7FF / %xE000-10FFFF ).
; The process of decoding into these code point integers is outside the
; scope of this grammar.
;
; Note: whenever there is a side condition (extra-grammatical constraint)
; that a parser must follow, we add a comment containing a side
; condition note number such as [SC1], and we describe the side conditions
; in more detail at the end of this file.

; =========================================================================

; -------------------------------------------------------------------------
; Top-level: a program is a single expression
; -------------------------------------------------------------------------

program         = ws exp ws

; -------------------------------------------------------------------------
; Expressions
; -------------------------------------------------------------------------

exp             = atom               ; atom in expression position
                                     ; (desugars to (array [] atom))
                / bracket-frame      ; [e1 e2 ... en] frame sugar
                / identifier         ; variable reference
                / string-lit         ; "..." string literal
                / paren-exp

bracket-frame   = "[" ws exp *( ws exp ) ws "]"
                  ; desugars to (frame [n] e1 ... en)
                  ; nested frames are flattened

string-lit      = DQUOTE *string-elem DQUOTE
                  ; A string-elem is either a char-lit or the empty
                  ; escape \&, defined below.  Empty escapes contribute
                  ; no characters; they are used to disambiguate
                  ; adjacent escape sequences (Haskell-style).
                  ; The whole desugars to (array [n] c1 ... cn).

paren-exp       = "(" ws paren-exp-body ws ")"

paren-exp-body  = array-exp
                / frame-exp
                / tapp-exp
                / iapp-exp
                / unbox-exp
                / let-exp
                / at-app-exp         ; @f sugar
                / app-exp            ; [SC3] must be last

array-exp       = %s"array" ws shape-lit *( ws atom )
                / %s"array" ws shape-lit ws type

frame-exp       = %s"frame" ws shape-lit *( ws exp )
                / %s"frame" ws shape-lit ws type

app-exp         = exp *( ws exp )      ; [SC1]
                  ; (f e1 ... en): first exp is the function

tapp-exp        = %s"t-app" ws exp *( ws type )

iapp-exp        = %s"i-app" ws exp *( ws ispace )

unbox-exp       = %s"unbox" ws "(" ws unbox-spec ws ")" ws exp

unbox-spec      = *( ispace-var ws ) identifier ws exp   ; [SC4]
                  ; binders for the unboxed ispaces and value, plus the
                  ; expression that yields the box being unboxed.

let-exp         = %s"let" ws "(" *( ws bind ) ws ")" ws exp

at-app-exp      = "@" ws exp ws type-args ws ispace-args *( ws exp )

type-args       = "(" *( ws type ) ws ")"
                / "_"

ispace-args     = "(" *( ws ispace ) ws ")"
                / "_"

; -------------------------------------------------------------------------
; Atoms (scalar-level values)
; -------------------------------------------------------------------------

atom            = base-val
                / "(" ws atom-body ws ")"

atom-body       = lambda
                / type-lambda
                / ispace-lambda
                / box-expr

lambda          = ( %s"fn" / %x03BB ) ws            ; fn or <lambda>
                  "(" *( ws pat ) ws ")" ws
                  exp

type-lambda     = ( %s"t-fn" / ( %s"t" %x03BB ) ) ws  ; t-fn or t<lambda>
                  "(" *( ws type-var ) ws ")" ws
                  exp

ispace-lambda   = ( %s"i-fn" / ( %s"i" %x03BB ) ) ws  ; i-fn or i<lambda>
                  "(" *( ws ispace-var ) ws ")" ws
                  exp

box-expr        = %s"box" ws "(" *( ws ispace ) ws ")" ws exp ws type

; -------------------------------------------------------------------------
; Patterns (used in lambda parameters)
; -------------------------------------------------------------------------

pat             = "(" ws identifier ws type ws ")"

; -------------------------------------------------------------------------
; Bindings (in let expressions)
; -------------------------------------------------------------------------

bind            = "(" ws bind-body ws ")"

bind-body       = val-bind
                / fun-bind
                / tfun-bind
                / ifun-bind
                / type-bind
                / ispace-bind
                / at-fun-bind

val-bind        = %s"val" ws identifier ws exp
                / %s"val" ws "(" ws val-typed-sig ws ")" ws exp

val-typed-sig   = identifier ws colon-type
                  ; inner of typed val-bind: "(" ws val-typed-sig ws ")"

fun-bind        = %s"fun" ws "(" ws fun-sig ws ")" ws exp

fun-sig         = identifier *( ws pat ) [ ws colon-type ]
                  ; inner of fun-bind: name, parameters, optional return type

tfun-bind       = %s"t-fun" ws "(" ws tfun-sig ws ")" ws exp

tfun-sig        = identifier ws "(" *( ws type-var ) ws ")"
                  [ ws colon-type ]
                  ; inner of tfun-bind: name, type parameters, optional
                  ; return type

ifun-bind       = %s"i-fun" ws "(" ws ifun-sig ws ")" ws exp

ifun-sig        = identifier ws "(" *( ws ispace-var ) ws ")"
                  [ ws colon-type ]
                  ; inner of ifun-bind: name, ispace parameters, optional
                  ; return type

type-bind       = %s"type" ws type-var ws type

ispace-bind     = %s"ispace" ws ispace-var ws ispace
                 ; NOTE: the paper (linked above) calls this concept
                 ; "index".

at-fun-bind     = %s"fun" ws "(" ws at-fun-sig ws ")" ws exp

at-fun-sig      = "@" ws identifier ws type-vars ws ispace-vars
                  *( ws pat ) ws colon-type
                  ; inner of at-fun-bind: name, type/ispace parameter
                  ; lists, value parameters, mandatory return type

type-vars       = "(" *( ws type-var ) ws ")"
                / "_"

ispace-vars     = "(" *( ws ispace-var ) ws ")"
                / "_"

colon-type      = ":" ws type
                  ; reusable form for type ascriptions; the inline option
                  ; [ ws colon-type ] used in fun-sig/tfun-sig/ifun-sig
                  ; expresses an absent-or-present return-type annotation

; -------------------------------------------------------------------------
; Types (source-level type expressions)
; -------------------------------------------------------------------------

type            = type-var           ; &name (atom) or *name (array)
                / base-type          ; Int, Bool, Float
                / bracket-type       ; [T d1 d2 ...] sugar
                / "(" ws type-paren ws ")"

base-type       = %s"Bool" / %s"Int" / %s"Float"

bracket-type    = "[" ws type *( ws ispace ) ws "]"
                  ; sugar for (A type ispace) with the ispaces spliced

type-paren      = array-type
                / arrow-type
                / forall-type
                / pi-type
                / sigma-type

array-type      = %s"A" ws type ws ispace

arrow-type      = ( "->" / %x2192 ) ws       ; -> or <arrow>
                  "(" *( ws type ) ws ")" ws type
                / ( "->" / %x2192 ) ws type ws type
                  ; single argument type, without the parenthesized list.
                  ; The two alternatives are disjoint: a single argument
                  ; type that starts with "(" must continue with one of
                  ; A, ->, Forall, Pi, Sigma (see type-paren), and none
                  ; of those tokens can start a type in the first
                  ; alternative's list (nor match its immediate ")").

forall-type     = ( %s"Forall" / %x2200 ) ws   ; Forall or <forall>
                  "(" *( ws type-var ) ws ")" ws type

pi-type         = ( %s"Pi" / %x03A0 ) ws        ; Pi or <Pi>
                  "(" *( ws ispace-var ) ws ")" ws type

sigma-type      = ( %s"Sigma" / %x03A3 ) ws     ; Sigma or <sigma>
                  "(" *( ws ispace-var ) ws ")" ws type

; -------------------------------------------------------------------------
; Type parameters
; -------------------------------------------------------------------------

type-var        = atom-type-var / array-type-var

atom-type-var   = "&" identifier

array-type-var  = "*" identifier

; -------------------------------------------------------------------------
; Dimensions, Shapes, Index Spaces
; -------------------------------------------------------------------------

dim             = "$" identifier     ; dimension variable
                / decimal            ; numeric dimension
                / "(" ws dim-arith ws ")"

dim-arith       = "+" *( ws dim )    ; addition
                / "*" *( ws dim )    ; multiplication
                / "-" *( ws dim )    ; subtraction

shape           = "@" identifier     ; shape variable
                / "(" ws shape-paren ws ")"
                / "[" *( ws ispace ) ws "]"   ; splice of ispaces (bracket)

shape-paren     = %s"dims" *( ws dim )           ; (dims d1 d2 ...)
                / "++" *( ws shape )             ; (++ s1 s2 ...)

shape-lit       = "[" *( ws decimal ) ws "]"
                  ; concrete shape literal e.g. [2 3]

ispace          = dim                ; a dimension
                / shape              ; a shape

ispace-var      = dim-ispace-var / shape-ispace-var

dim-ispace-var    = "$" identifier

shape-ispace-var  = "@" identifier

; -------------------------------------------------------------------------
; Base values (literals)
; -------------------------------------------------------------------------

base-val        = bool-val / num-val

bool-val        = "#t" / "#f"

num-val         = [ "+" / "-" ] ( float-lit / decimal )
                  ; float-lit must be tried before decimal

; -------------------------------------------------------------------------
; Identifiers
; -------------------------------------------------------------------------
;
; An identifier is a sequence of non-disallowed characters whose first
; character is also not a digit. The result must not be a keyword
; (see the `keyword` rule below for the full list).
;
; Disallowed characters are: whitespace and ( ) [ ] { } " , ' ` ; # | \ @
;
; The allowed ASCII ranges below are the complement of those disallowed
; characters within the printable ASCII range (%x21-%x7E).

identifier      = id-start *id-continue        ; [SC2]
                  ; must not match a keyword

id-start        = %x00-08      ; NUL and C0 controls (non-whitespace)
                / %x0E-1F      ; C0 controls (non-whitespace)
                / %x21         ; !
                / %x24-26      ; $ % &
                / %x2A-2B      ; * +
                / %x2D-2F      ; - . /
                / %x3A         ; :
                / %x3C-3F      ; < = > ?
                / %x41-5A      ; A-Z
                / %x5E-5F      ; ^ _
                / %x61-7A      ; a-z
                / %x7E-7F      ; ~ DEL
                / non-ascii

id-continue     = %x00-08      ; NUL and C0 controls (non-whitespace)
                / %x0E-1F      ; C0 controls (non-whitespace)
                / %x21         ; !
                / %x24-26      ; $ % &
                / %x2A-2B      ; * +
                / %x2D-3A      ; - . / 0-9 :
                / %x3C-3F      ; < = > ?
                / %x41-5A      ; A-Z
                / %x5E-5F      ; ^ _
                / %x61-7A      ; a-z
                / %x7E-7F      ; ~ DEL
                / non-ascii

; Non-ASCII characters that are not Unicode whitespace and not
; surrogates.  Covers BMP (%x80-FFFF) and supplementary planes
; (%x10000-10FFFF) with holes punched for every code point
; where Haskell's Data.Char.isSpace returns True:
;   %xA0           NO-BREAK SPACE
;   %x1680         OGHAM SPACE MARK
;   %x2000-200A    EN QUAD through HAIR SPACE
;   %x2028         LINE SEPARATOR
;   %x2029         PARAGRAPH SEPARATOR
;   %x202F         NARROW NO-BREAK SPACE
;   %x205F         MEDIUM MATHEMATICAL SPACE
;   %x3000         IDEOGRAPHIC SPACE
; Note, the Private Use Area (%xE000-F8FF) and unassigned ranges are
; accepted by the parser.

non-ascii       = %x80-9F
                / %xA1-167F
                / %x1681-1FFF
                / %x200B-2027
                / %x202A-202E
                / %x2030-205E
                / %x2060-2FFF
                / %x3001-D7FF
                / %xE000-10FFFF

; -------------------------------------------------------------------------
; Reserved keywords (side condition [SC2])
; -------------------------------------------------------------------------
;
; The `keyword` rule below enumerates the reserved words of Remora that
; the `identifier` rule must not match (see [SC2]).  Keywords use the
; case-sensitive %s"..." notation [RFC 7405], since Remora keywords are
; matched case-sensitively.
;
; This rule is not invoked directly by the parser.  Instead the parser
; matches each individual keyword inline at the rule that uses it
; (e.g. "array" inside array-exp, "fn" inside lambda), and the
; post-parsing check `check-tree-no-keyword-identifiers` rejects any
; identifier whose text appears in the keyword list at
; *remora-keywords-as-natlists* (defined in identifier-syntax.lisp).
;
; The book `check-keywords.lisp` walks the parsed grammar's `keyword`
; rule and certifies that the sequences it lists are exactly the
; entries of *remora-keywords-as-natlists*.  If the two ever drift
; out of sync, that book will fail to certify.

keyword         = %s"array" / %s"frame"
                / %s"t-app" / %s"i-app"
                / %s"unbox" / %s"box" / %s"dims"
                / %s"fn" / %x03BB           ; fn or lambda
                / %s"t-fn" / %s"t" %x03BB   ; t-fn or t<lambda>
                / %s"i-fn" / %s"i" %x03BB   ; i-fn or i<lambda>
                / %s"A"
                / %s"->" / %x2192           ; -> or rightwards arrow
                                            ; (%s is redundant for "->"
                                            ; since it has no letters; kept
                                            ; to keep the check-keywords
                                            ; extractor simple --- it only
                                            ; handles :sensitive char-vals)
                / %s"Forall" / %x2200       ; Forall or for-all
                / %s"Pi" / %x03A0           ; Pi or capital Pi
                / %s"Sigma" / %x03A3        ; Sigma or capital Sigma
                / %s"let" / %s"type" / %s"ispace"
                / %s"fun" / %s"t-fun" / %s"i-fun" / %s"val"

; -------------------------------------------------------------------------
; Lexical primitives
; -------------------------------------------------------------------------

decimal         = 1*DIGIT

float-lit       = 1*DIGIT "." 1*DIGIT [ exponent ]
                / 1*DIGIT exponent

exponent        = %i"e" [ "+" / "-" ] 1*DIGIT

; String character: any character except " and \, or an escape sequence.
; Modeled on Haskell's character-literal escapes as accepted by Haskell
; Remora.  The empty escape \& is recognized at the string-element level
; below (not as a char-lit), since \& produces no character.

char-lit    = %x00-21             ; any char below "
            / %x23-5B             ; between " and \
            / %x5D-D7FF           ; between \ and surrogate range
            / %xE000-10FFFF       ; above surrogates
              ; The Haskell Report restricts literal characters in strings
              ; to graphic characters and space, but the Haskell Remora parser
              ; accepts any non-backslash, non-quote character.
              ; The ranges above reflect the actual behavior.
            / "\" escape-char

escape-char     = char-escape
                / ascii-escape
                / caret-escape
                / num-escape

; Single-character mnemonics
char-escape     = %s"a" / %s"b" / %s"f" / %s"n" / %s"r" / %s"t" / %s"v"
                / "\" / DQUOTE / "'"

; ASCII control character names (34 names for %x00-%x20 and %x7F).
; SOH must be matched before SO (longest-match); all other
; alternatives are prefix-free.
ascii-escape    = %s"NUL" / %s"SOH" / %s"STX" / %s"ETX" / %s"EOT" / %s"ENQ"
                / %s"ACK" / %s"BEL" / %s"BS"  / %s"HT"  / %s"LF"  / %s"VT"
                / %s"FF"  / %s"CR"  / %s"SO"  / %s"SI"  / %s"DLE" / %s"DC1"
                / %s"DC2" / %s"DC3" / %s"DC4" / %s"NAK" / %s"SYN" / %s"ETB"
                / %s"CAN" / %s"EM"  / %s"SUB" / %s"ESC" / %s"FS"  / %s"GS"
                / %s"RS"  / %s"US"  / %s"SP"  / %s"DEL"

; Caret notation: \^@ through \^_ (to get %x00-%x1F)
caret-escape    = "^" %x40-5F         ; @ A-Z [ \ ] ^ _

; Numeric character codes
num-escape      = 1*DIGIT             ; decimal (0-1114111)
                / %i"o" 1*(%x30-37)     ; octal
                / %i"x" 1*HEXDIG        ; hexadecimal

; Empty escape: a string-gap separator producing no character.  Used
; to disambiguate adjacent escape sequences.  For example "\5\&7" is
; two characters --- codepoint 5 (the ENQ control character) followed
; by the digit '7' (codepoint 55) --- whereas "\57" is the single
; character with codepoint 57 (the digit '9').  The empty escape
; carries no semantic content and is absorbed at parse time.
;
; Compatibility note: our grammar accepts \& as a string-elem in any
; position, following the Haskell Report's lexical syntax for string
; literals.  The Haskell Remora reference implementation parses string
; literals with Megaparsec's charLiteral combinator, which fails on a
; leading \&.  As a consequence, Haskell Remora rejects "\&" and "\&a"
; but accepts "a\&", "\SOH\&", and "a\&\&b\&\&".  We accept all of
; these.  Our printer emits \& only between adjacent char-lits that
; would otherwise merge on re-parse (see needs-empty-escape-between in
; printer.lisp), so output produced from our printer is parseable by
; either implementation.
empty-escape = "\&"

; A string element is either a real char-lit or an empty escape.
string-elem     = char-lit / empty-escape

; -------------------------------------------------------------------------
; Whitespace and comments
; -------------------------------------------------------------------------

; Whitespace is defined by Haskell's Data.Char.isSpace

ws              = *( unicode-space / comment )

unicode-space   = %x09         ; HORIZONTAL TAB
                / %x0A         ; LINE FEED
                / %x0B         ; VERTICAL TAB
                / %x0C         ; FORM FEED
                / %x0D         ; CARRIAGE RETURN
                / %x20         ; SPACE
                / %xA0         ; NO-BREAK SPACE
                / %x1680       ; OGHAM SPACE MARK
                / %x2000-200A  ; EN QUAD through HAIR SPACE
                / %x2028       ; LINE SEPARATOR
                / %x2029       ; PARAGRAPH SEPARATOR
                / %x202F       ; NARROW NO-BREAK SPACE
                / %x205F       ; MEDIUM MATHEMATICAL SPACE
                / %x3000       ; IDEOGRAPHIC SPACE

comment         = ";" *( %x00-09 / %x0B-D7FF / %xE000-10FFFF )
                  ; Consumes ";" then everything except LF (%x0A).
                  ; The LF itself is not part of the comment; it is
                  ; consumed separately by unicode-space in ws.
                  ; A comment at end-of-input (no trailing LF) is valid.

; -------------------------------------------------------------------------
; Standard ABNF core rules used above
; We duplicate these since currently defgrammar does not have a feature
; for importing them.
; -------------------------------------------------------------------------

DIGIT  = %x30-39
DQUOTE = %x22
HEXDIG = DIGIT / "A" / "B" / "C" / "D" / "E" / "F"
               / "a" / "b" / "c" / "d" / "e" / "f"

; =========================================================================
; Side conditions (extra-grammatical constraints)
; =========================================================================
;
; The following constraints are not expressible in ABNF and must be
; enforced by any parser implementation.  They are referenced from the
; grammar rules above using [SC1], [SC2], etc.
;
; [SC1] Max-munch tokenization  (tagged on: app-exp)
;
;   This side condition occurs in more than 30 situations, so we are
;   not tagging them in general.  We have tagged one example --
;   that of app-exp, which we consider in the next paragraph.
;
;   Tokens -- identifiers, decimals, and float-lits -- must be matched
;   greedily, consuming as many legal characters as possible.  Without
;   this convention the grammar is formally ambiguous: wherever ws may
;   be empty between elements (e.g. app-exp = exp *( ws exp )), an
;   input such as "xy" admits two parse trees (one identifier vs. two
;   adjacent identifiers).  Max-munch at the token level resolves the
;   ambiguity by having the first token consume all available characters.
;
;   As a corollary, keyword literals in the grammar (e.g. "fn", "array",
;   "let") must not match when followed immediately by an id-continue
;   character: "fn2" is one identifier, not the keyword "fn" followed
;   by "2".  The Haskell reference implementation enforces this with
;   notFollowedBy (satisfy isAlphaNum) in lKeyword; a parser using
;   max-munch gets the same effect automatically.
;
;   The Haskell reference implementation achieves max-munch via
;   Megaparsec's greedy "many" combinator in lId (src/Parser.hs).
;
; [SC2] Keyword exclusion from identifiers (tagged on: identifier)
;
;   The text matched by the "identifier" production must not equal any
;   reserved keyword.  Every keyword happens to match the identifier
;   production (all are sequences of id-start and id-continue chars),
;   but the language forbids their use as variable names.  This is a
;   context-sensitive constraint that ABNF cannot express.
;
;   The full keyword list is given by the `keyword` rule (above the
;   lexical primitives section).  That rule is not invoked by the
;   parser; it is cross-checked for consistency against the keyword
;   list used by the parser (*remora-keywords-as-natlists* in
;   identifier-syntax.lisp), by the book check-keywords.lisp.
;   The Haskell reference implementation checks this at the end of
;   lId, failing if the accepted text is in the keyword list.
;
; [SC3] app-exp must be last in paren-exp-body (tagged on: paren-exp-body)
;
;   Because the grammar does not exclude keywords from identifiers
;   (see [SC2]), a parser that tries app-exp early would greedily parse
;   forms such as (array ...) or (let ...) as applications of keyword-
;   named variables.  The grammar therefore places app-exp last among
;   the paren-exp-body alternatives, ensuring that keyword-headed forms
;   match their specific rules first.
;
;   The Haskell reference implementation uses a different ordering
;   (App appears early), but this works because lId rejects keywords,
;   causing App to fail on keyword-headed forms.
;
; [SC4] unbox-spec ispace-var lookahead (tagged on: unbox-spec)
;
;   In the Haskell parser for unbox-exp, each ispace-var (called
;   extent-param there) is guarded by notFollowedBy (symbol ")"), so
;   that the last ispace-var-like token preceding the closing paren is
;   left for the mandatory "identifier" to match instead.  ABNF cannot
;   express this one-token lookahead; the grammar uses a plain
;   *( ispace-var ws ) repetition (now factored into the unbox-spec rule).
;   For well-formed input the two approaches produce identical parse
;   trees.  The difference is visible only in error messages for
;   malformed input.


; =========================================================================
