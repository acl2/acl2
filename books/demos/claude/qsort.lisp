; In-place quicksort on a stobj array of rationals.
;
; Written with Claude Code (Opus 4.8, max effort).
;
; This book defines an efficient in-place quicksort (Lomuto partition scheme)
; operating on a single-field stobj whose field is a resizable array of
; rationals, and proves:
;
;   * termination (the function is admitted under a measure);
;   * that sorting preserves the array length and well-formedness (stp);
;   * PERMUTATION correctness: the array after sorting is a permutation of the
;     array before sorting -- stated both as preservation of element multiplicities
;     (how-many-qsort) and as (perm ... ...) (perm-nth0-qsort);
;   * bound-preservation lemmas (qsort rearranges values within their range and
;     so preserves "all <= x" / "all >= x" over any enclosing range), and the
;     left half of the Lomuto partition invariant (part-loop-left).
;
; The array of a stobj st is the list (nth 0 st); the accessor (ari i st) is
; (nth i (nth 0 st)) and (update-ari i v st) updates that list, so stobj
; reasoning reduces to standard nth/update-nth list reasoning.

(in-package "ACL2")

(include-book "sorting/convert-perm-to-how-many" :dir :system) ; perm, how-many, bridge
(include-book "std/lists/update-nth" :dir :system)
(include-book "std/lists/nth" :dir :system)

;; ---------------------------------------------------------------------------
;; The stobj: a resizable array of rationals.
;; Generated accessors: (ari i st), (update-ari i v st), (ar-length st),
;; recognizers stp / arp.
;; ---------------------------------------------------------------------------

(defstobj st
  (ar :type (array rational (0)) :initially 0 :resizable t))

;; ---------------------------------------------------------------------------
;; swap, and its array-interface lemmas.
;; ---------------------------------------------------------------------------

(defun swap (i j st)
  (declare (xargs :stobjs st
                  :guard (and (stp st) (natp i) (natp j)
                              (< i (ar-length st)) (< j (ar-length st)))
                  :verify-guards nil))
  (let* ((vi (ari i st))
         (vj (ari j st))
         (st (update-ari i vj st)))
    (update-ari j vi st)))

(defthm ar-length-swap
  (implies (and (natp i) (natp j) (< i (ar-length st)) (< j (ar-length st)))
           (equal (ar-length (swap i j st)) (ar-length st))))

(defthm ari-swap
  (implies (and (natp i) (natp j) (natp k))
           (equal (ari k (swap i j st))
                  (cond ((equal k i) (ari j st))
                        ((equal k j) (ari i st))
                        (t (ari k st))))))

;; Interface lemmas for ari / update-ari / stp, after which we hide the stobj
;; internals and reason purely at the accessor level.

(defthm rationalp-nth-arp
  (implies (and (arp l) (natp i) (< i (len l)))
           (rationalp (nth i l))))

(defthm arp-update-nth
  (implies (and (arp l) (rationalp v) (natp i) (< i (len l)))
           (arp (update-nth i v l))))

(defthm rationalp-ari
  (implies (and (stp st) (natp i) (< i (ar-length st)))
           (rationalp (ari i st)))
  :hints (("Goal" :in-theory (enable ari ar-length stp))))

(defthm ari-update-ari
  (implies (and (natp k) (natp i))
           (equal (ari k (update-ari i v st))
                  (if (equal k i) v (ari k st))))
  :hints (("Goal" :in-theory (enable ari update-ari))))

(defthm ar-length-update-ari
  (implies (and (natp i) (< i (ar-length st)))
           (equal (ar-length (update-ari i v st))
                  (ar-length st)))
  :hints (("Goal" :in-theory (enable ar-length update-ari))))

(defthm stp-update-ari
  (implies (and (stp st) (natp i) (< i (ar-length st)) (rationalp v))
           (stp (update-ari i v st)))
  :hints (("Goal" :in-theory (enable stp ar-length update-ari))))

(defthm stp-swap
  (implies (and (stp st) (natp i) (natp j) (< i (ar-length st)) (< j (ar-length st)))
           (stp (swap i j st)))
  :hints (("Goal" :in-theory (e/d (swap) (update-ari ari ar-length stp)))))

(in-theory (disable ari update-ari ar-length swap stp))

;; Guards verified at the interface-lemma level (ari/update-ari disabled), so
;; the array stays well-formed and every index stays in bounds.
(verify-guards swap)

;; ---------------------------------------------------------------------------
;; The Lomuto partition: part-loop is the scanning inner loop; partition picks
;; the last element as pivot, partitions, and returns the pivot's final index.
;; ---------------------------------------------------------------------------

(defun part-loop (j i hi pivot st)
  (declare (xargs :stobjs st
                  :guard (and (stp st) (natp j) (natp i) (natp hi) (<= i j) (<= j hi)
                              (< hi (ar-length st)) (rationalp pivot))
                  :measure (nfix (- hi (nfix j)))
                  :verify-guards nil))
  (if (or (not (natp j)) (not (natp hi)) (>= j hi))
      (mv i st)
    (if (<= (ari j st) pivot)
        (let ((st (swap i j st)))
          (part-loop (+ j 1) (+ i 1) hi pivot st))
      (part-loop (+ j 1) i hi pivot st))))

(defun partition (lo hi st)
  (declare (xargs :stobjs st
                  :guard (and (stp st) (natp lo) (natp hi) (<= lo hi) (< hi (ar-length st)))
                  :verify-guards nil))
  (let ((pivot (ari hi st)))
    (mv-let (i st)
        (part-loop lo lo hi pivot st)
      (let ((st (swap i hi st)))
        (mv i st)))))

;; part-loop preserves length / stp, and returns an index in [i, hi].

(defthm ar-length-part-loop
  (implies (and (natp i) (natp j) (natp hi) (<= i j) (<= j hi) (< hi (ar-length st)))
           (equal (ar-length (mv-nth 1 (part-loop j i hi pivot st)))
                  (ar-length st)))
  :hints (("Goal" :induct (part-loop j i hi pivot st))))

(defthm stp-part-loop
  (implies (and (stp st) (natp i) (natp j) (natp hi) (<= i j) (<= j hi) (< hi (ar-length st)))
           (stp (mv-nth 1 (part-loop j i hi pivot st))))
  :hints (("Goal" :induct (part-loop j i hi pivot st))))

(defthm part-loop-i-lower
  (implies (natp i)
           (<= i (mv-nth 0 (part-loop j i hi pivot st))))
  :hints (("Goal" :induct (part-loop j i hi pivot st)))
  :rule-classes :linear)

(defthm part-loop-i-upper
  (implies (and (natp i) (natp j) (natp hi) (<= i j) (<= j hi))
           (<= (mv-nth 0 (part-loop j i hi pivot st)) hi))
  :hints (("Goal" :induct (part-loop j i hi pivot st)))
  :rule-classes :linear)

(defthm natp-part-loop-i
  (implies (natp i) (natp (mv-nth 0 (part-loop j i hi pivot st))))
  :hints (("Goal" :induct (part-loop j i hi pivot st)))
  :rule-classes :type-prescription)

(verify-guards part-loop)

;; partition preserves length / stp, and returns an index in [lo, hi].

(defthm stp-partition
  (implies (and (stp st) (natp lo) (natp hi) (<= lo hi) (< hi (ar-length st)))
           (stp (mv-nth 1 (partition lo hi st))))
  :hints (("Goal" :do-not-induct t
           :in-theory (enable partition)
           :use ((:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st)))
                 (:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance stp-part-loop (j lo) (i lo) (pivot (ari hi st)))
                 (:instance ar-length-part-loop (j lo) (i lo) (pivot (ari hi st)))
                 (:instance stp-swap
                            (i (mv-nth 0 (part-loop lo lo hi (ari hi st) st)))
                            (j hi)
                            (st (mv-nth 1 (part-loop lo lo hi (ari hi st) st))))))))

(defthm natp-partition-i
  (implies (natp lo) (natp (mv-nth 0 (partition lo hi st))))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st))))))
  :rule-classes :type-prescription)

(defthm partition-lo
  (implies (and (natp lo) (natp hi) (<= lo hi))
           (<= lo (mv-nth 0 (partition lo hi st))))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance part-loop-i-lower (j lo) (i lo) (pivot (ari hi st))))))
  :rule-classes :linear)

(defthm partition-hi
  (implies (and (natp lo) (natp hi) (<= lo hi))
           (<= (mv-nth 0 (partition lo hi st)) hi))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st))))))
  :rule-classes :linear)

(defthm ar-length-partition
  (implies (and (natp lo) (natp hi) (<= lo hi) (< hi (ar-length st)))
           (equal (ar-length (mv-nth 1 (partition lo hi st))) (ar-length st)))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st)))
                 (:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance ar-length-part-loop (j lo) (i lo) (pivot (ari hi st)))
                 (:instance ar-length-swap
                            (i (mv-nth 0 (part-loop lo lo hi (ari hi st) st)))
                            (j hi)
                            (st (mv-nth 1 (part-loop lo lo hi (ari hi st) st))))))))

(verify-guards partition
  :hints (("Goal" :in-theory (enable mv-nth)
           :use ((:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st)))
                 (:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance stp-part-loop (j lo) (i lo) (pivot (ari hi st)))
                 (:instance ar-length-part-loop (j lo) (i lo) (pivot (ari hi st)))))))

;; ---------------------------------------------------------------------------
;; qsort.  Termination uses the partition index bounds (partition-lo/hi).
;; ---------------------------------------------------------------------------

(defun qsort (lo hi st)
  (declare (xargs :stobjs st
                  :guard (stp st)
                  :measure (nfix (- hi (nfix lo)))
                  :hints (("Goal" :in-theory (disable partition part-loop)
                           :use ((:instance partition-lo)
                                 (:instance partition-hi)
                                 (:instance natp-partition-i))))
                  :verify-guards nil))
  (if (or (not (natp lo)) (not (natp hi)) (>= hi (ar-length st)) (>= lo hi))
      st
    (mv-let (p st)
        (partition lo hi st)
      (let ((st (qsort lo (- p 1) st)))
        (qsort (+ p 1) hi st)))))

(defthm ar-length-qsort
  (equal (ar-length (qsort lo hi st)) (ar-length st))
  :hints (("Goal" :induct (qsort lo hi st) :in-theory (disable partition))))

(defthm stp-qsort
  (implies (stp st) (stp (qsort lo hi st)))
  :hints (("Goal" :induct (qsort lo hi st) :in-theory (disable partition))))

;; With the guard weakened to just (stp st) -- the body's own base test
;; supplies natp/in-range facts for the recursive case -- qsort verifies, so
;; it executes as compiled in-place array code rather than interpreted.
(verify-guards qsort
  :hints (("Goal" :in-theory (e/d (mv-nth) (partition))
           :use ((:instance natp-partition-i)
                 (:instance stp-partition)))))

;; ===========================================================================
;; PERMUTATION CORRECTNESS.
;; A swap is a transposition of the whole array list, hence preserves the
;; multiplicity (how-many) of every element; this lifts through part-loop,
;; partition, and qsort.
;; ===========================================================================

(defthm how-many-update-nth
  (implies (and (natp m) (< m (len l)))
           (equal (how-many e (update-nth m v l))
                  (if (equal e v)
                      (if (equal e (nth m l)) (how-many e l) (+ 1 (how-many e l)))
                    (if (equal e (nth m l)) (- (how-many e l) 1) (how-many e l)))))
  :hints (("Goal" :induct (nth m l) :in-theory (enable nth update-nth))))

(defthm how-many-transposition
  (implies (and (natp a) (natp b) (< a (len l)) (< b (len l)))
           (equal (how-many e (update-nth b (nth a l) (update-nth a (nth b l) l)))
                  (how-many e l)))
  :hints (("Goal" :in-theory (enable how-many-update-nth))))

(defthm nth-0-update-ari
  (equal (nth 0 (update-ari i v st))
         (update-nth i v (nth 0 st)))
  :hints (("Goal" :in-theory (enable update-ari))))

(defthm nth-0-swap
  (equal (nth 0 (swap i j st))
         (update-nth j (nth i (nth 0 st))
                     (update-nth i (nth j (nth 0 st)) (nth 0 st))))
  :hints (("Goal" :in-theory (enable swap ari))))

(defthm how-many-swap
  (implies (and (natp i) (natp j) (< i (ar-length st)) (< j (ar-length st)))
           (equal (how-many e (nth 0 (swap i j st)))
                  (how-many e (nth 0 st))))
  :hints (("Goal" :in-theory (enable ar-length))))

(in-theory (disable nth-0-swap))

(defthm how-many-part-loop
  (implies (and (natp i) (natp j) (natp hi) (<= i j) (<= j hi) (< hi (ar-length st)))
           (equal (how-many e (nth 0 (mv-nth 1 (part-loop j i hi pivot st))))
                  (how-many e (nth 0 st))))
  :hints (("Goal" :induct (part-loop j i hi pivot st)
           :do-not '(eliminate-destructors)
           :in-theory (disable nth-0-swap nth-when-zp (:definition nth)))))

(defthm how-many-partition
  (implies (and (natp lo) (natp hi) (<= lo hi) (< hi (ar-length st)))
           (equal (how-many e (nth 0 (mv-nth 1 (partition lo hi st))))
                  (how-many e (nth 0 st))))
  :hints (("Goal" :do-not-induct t :do-not '(eliminate-destructors)
           :in-theory (e/d (partition) (nth-0-swap nth-when-zp (:definition nth)))
           :use ((:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st)))
                 (:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance ar-length-part-loop (j lo) (i lo) (pivot (ari hi st)))
                 (:instance how-many-part-loop (j lo) (i lo) (pivot (ari hi st)))
                 (:instance how-many-swap
                            (i (mv-nth 0 (part-loop lo lo hi (ari hi st) st)))
                            (j hi)
                            (st (mv-nth 1 (part-loop lo lo hi (ari hi st) st))))))))

(defthm how-many-qsort
  (equal (how-many e (nth 0 (qsort lo hi st)))
         (how-many e (nth 0 st)))
  :hints (("Goal" :induct (qsort lo hi st)
           :do-not '(eliminate-destructors)
           :in-theory (disable partition nth-0-swap nth-when-zp (:definition nth)))))

;; The array after qsort is a permutation of the array before qsort.
(defthm perm-nth0-qsort
  (perm (nth 0 (qsort lo hi st)) (nth 0 st))
  :hints (("Goal"
           :use ((:instance convert-perm-to-how-many
                            (x (nth 0 (qsort lo hi st))) (y (nth 0 st)))
                 (:instance how-many-qsort
                            (e (perm-counter-example (nth 0 (qsort lo hi st)) (nth 0 st))))))))

;; ===========================================================================
;; BOUND PRESERVATION (toward sortedness).
;; qsort only rearranges elements within [lo,hi], so for any enclosing range
;; [a,a+m) it preserves "every element <= x" and "every element >= x".
;; Also: the left half of the Lomuto invariant (part-loop-left).
;; ===========================================================================

(defun rng-<= (lo n x st)
  (declare (xargs :stobjs st :measure (nfix n) :verify-guards nil))
  (if (zp n) t (and (<= (ari lo st) x) (rng-<= (+ lo 1) (- n 1) x st))))

(defun rng->= (lo n x st)
  (declare (xargs :stobjs st :measure (nfix n) :verify-guards nil))
  (if (zp n) t (and (<= x (ari lo st)) (rng->= (+ lo 1) (- n 1) x st))))

(defthm rng-<=-implies-ari
  (implies (and (rng-<= lo n x st) (natp lo) (natp n) (natp k) (<= lo k) (< k (+ lo n)))
           (<= (ari k st) x))
  :hints (("Goal" :induct (rng-<= lo n x st))))

(defthm rng->=-implies-ari
  (implies (and (rng->= lo n x st) (natp lo) (natp n) (natp k) (<= lo k) (< k (+ lo n)))
           (<= x (ari k st)))
  :hints (("Goal" :induct (rng->= lo n x st))))

;; part-loop only modifies positions in [i, hi).
(defthm ari-part-loop-out
  (implies (and (natp i) (natp j) (natp hi) (<= i j) (<= j hi) (natp k)
                (or (< k i) (<= hi k)))
           (equal (ari k (mv-nth 1 (part-loop j i hi pivot st)))
                  (ari k st)))
  :hints (("Goal" :induct (part-loop j i hi pivot st))))

(defthm update-ari-preserves-rng-<=
  (implies (and (rng-<= lo n x st) (<= val x) (natp lo) (natp n) (natp i))
           (rng-<= lo n x (update-ari i val st)))
  :hints (("Goal" :induct (rng-<= lo n x st))))

(defthm update-ari-preserves-rng->=
  (implies (and (rng->= lo n x st) (<= x val) (natp lo) (natp n) (natp i))
           (rng->= lo n x (update-ari i val st)))
  :hints (("Goal" :induct (rng->= lo n x st))))

(defthm swap-preserves-rng-<=
  (implies (and (rng-<= lo n x st) (natp lo) (natp n) (natp i) (natp j)
                (<= lo i) (< i (+ lo n)) (<= lo j) (< j (+ lo n)))
           (rng-<= lo n x (swap i j st)))
  :hints (("Goal" :in-theory (enable swap))))

(defthm swap-preserves-rng->=
  (implies (and (rng->= lo n x st) (natp lo) (natp n) (natp i) (natp j)
                (<= lo i) (< i (+ lo n)) (<= lo j) (< j (+ lo n)))
           (rng->= lo n x (swap i j st)))
  :hints (("Goal" :in-theory (enable swap))))

(defthm part-loop-preserves-rng-<=
  (implies (and (rng-<= a m x st) (natp a) (natp m) (natp i) (natp j) (natp hi)
                (<= i j) (<= j hi) (<= a i) (<= hi (+ a m)))
           (rng-<= a m x (mv-nth 1 (part-loop j i hi pivot st))))
  :hints (("Goal" :induct (part-loop j i hi pivot st))))

(defthm part-loop-preserves-rng->=
  (implies (and (rng->= a m x st) (natp a) (natp m) (natp i) (natp j) (natp hi)
                (<= i j) (<= j hi) (<= a i) (<= hi (+ a m)))
           (rng->= a m x (mv-nth 1 (part-loop j i hi pivot st))))
  :hints (("Goal" :induct (part-loop j i hi pivot st))))

(defthm partition-preserves-rng-<=
  (implies (and (rng-<= a m x st) (natp a) (natp m) (natp lo) (natp hi)
                (<= lo hi) (<= a lo) (< hi (+ a m)) (< hi (ar-length st)))
           (rng-<= a m x (mv-nth 1 (partition lo hi st))))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st)))
                 (:instance part-loop-i-lower (j lo) (i lo) (pivot (ari hi st)))
                 (:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance part-loop-preserves-rng-<= (j lo) (i lo) (pivot (ari hi st)))
                 (:instance swap-preserves-rng-<=
                            (lo a) (n m) (x x)
                            (i (mv-nth 0 (part-loop lo lo hi (ari hi st) st))) (j hi)
                            (st (mv-nth 1 (part-loop lo lo hi (ari hi st) st))))))))

(defthm partition-preserves-rng->=
  (implies (and (rng->= a m x st) (natp a) (natp m) (natp lo) (natp hi)
                (<= lo hi) (<= a lo) (< hi (+ a m)) (< hi (ar-length st)))
           (rng->= a m x (mv-nth 1 (partition lo hi st))))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st)))
                 (:instance part-loop-i-lower (j lo) (i lo) (pivot (ari hi st)))
                 (:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance part-loop-preserves-rng->= (j lo) (i lo) (pivot (ari hi st)))
                 (:instance swap-preserves-rng->=
                            (lo a) (n m) (x x)
                            (i (mv-nth 0 (part-loop lo lo hi (ari hi st) st))) (j hi)
                            (st (mv-nth 1 (part-loop lo lo hi (ari hi st) st))))))))

(defthm partition-bounds-fc
  (implies (and (natp lo) (natp hi) (<= lo hi))
           (and (<= lo (mv-nth 0 (partition lo hi st)))
                (<= (mv-nth 0 (partition lo hi st)) hi)
                (natp (mv-nth 0 (partition lo hi st)))))
  :hints (("Goal" :use (partition-lo partition-hi natp-partition-i)))
  :rule-classes ((:forward-chaining
                  :trigger-terms ((mv-nth 0 (partition lo hi st))))))

(defthm qsort-preserves-rng-<=
  (implies (and (rng-<= a m x st) (natp a) (natp m) (natp lo) (natp hi)
                (<= a lo) (< hi (+ a m)))
           (rng-<= a m x (qsort lo hi st)))
  :hints (("Goal" :induct (qsort lo hi st)
           :in-theory (disable partition rng->=-implies-ari rng-<=-implies-ari))
          ("Subgoal *1/2" :use ((:instance partition-lo)
                                (:instance partition-hi)
                                (:instance natp-partition-i)))))

(defthm qsort-preserves-rng->=
  (implies (and (rng->= a m x st) (natp a) (natp m) (natp lo) (natp hi)
                (<= a lo) (< hi (+ a m)))
           (rng->= a m x (qsort lo hi st)))
  :hints (("Goal" :induct (qsort lo hi st)
           :in-theory (disable partition rng->=-implies-ari rng-<=-implies-ari))
          ("Subgoal *1/2" :use ((:instance partition-lo)
                                (:instance partition-hi)
                                (:instance natp-partition-i)))))

;; Left half of the Lomuto invariant: after part-loop, positions [i, i') hold
;; values <= pivot (i' is the returned boundary index).
(defthm part-loop-left
  (implies (and (natp i) (natp j) (natp hi) (<= i j) (<= j hi) (natp k)
                (<= i k) (< k (mv-nth 0 (part-loop j i hi pivot st))))
           (<= (ari k (mv-nth 1 (part-loop j i hi pivot st))) pivot))
  :hints (("Goal" :induct (part-loop j i hi pivot st))))

;; ===========================================================================
;;
;;                     SORTEDNESS (ORDERING) CORRECTNESS
;;
;; The events below establish that the quicksort produces a non-decreasing
;; array.  Combined with the permutation result (PERM-NTH0-QSORT) above, this
;; gives full functional correctness of the sort, packaged at the end as
;; SORT-ARRAY-CORRECT.
;; ===========================================================================

;; A strict "all > x over [lo, lo+n)" range predicate, used to express the
;; right half of the Lomuto partition invariant, plus its element extractor.
(defun rng-> (lo n x st)
  (declare (xargs :stobjs st :measure (nfix n) :verify-guards nil))
  (if (zp n) t (and (< x (ari lo st)) (rng-> (+ lo 1) (- n 1) x st))))

(defthm rng->-implies-ari
  (implies (and (rng-> lo n x st) (natp lo) (natp n) (natp k) (<= lo k) (< k (+ lo n)))
           (< x (ari k st)))
  :hints (("Goal" :induct (rng-> lo n x st))))

(defthm update-ari-out-preserves-rng->
  (implies (and (natp lo) (natp n) (natp m) (or (< m lo) (<= (+ lo n) m)))
           (equal (rng-> lo n x (update-ari m val st))
                  (rng-> lo n x st)))
  :hints (("Goal" :induct (rng-> lo n x st))))

(defthm rng->-update-top
  (implies (and (rng-> lo m pivot st) (< pivot val) (natp lo) (natp m))
           (rng-> lo (+ m 1) pivot (update-ari (+ lo m) val st)))
  :hints (("Goal" :induct (rng-> lo m pivot st)
           :expand ((rng-> lo (+ 1 m) pivot (update-ari (+ lo m) val st))
                    (rng-> lo 1 pivot (update-ari lo val st))))))

;; Arithmetic-5 supplies the +/- cancellation needed below.  It is included
;; here (after the events above, which do not need it) and remains active for
;; the rest of the book.
(include-book "arithmetic-5/top" :dir :system)

;; The Lomuto swap, applied at the boundary, shifts the ">"-region up by one.
(defthm rng->-swap-step
  (implies (and (rng-> i (- j i) pivot st) (natp i) (natp j) (< i j))
           (rng-> (+ i 1) (- j i) pivot (swap i j st)))
  :hints (("Goal" :in-theory (e/d (swap) (rng->-update-top update-ari-out-preserves-rng->))
           :expand ((rng-> i (- j i) pivot st))
           :use ((:instance rng->-update-top
                            (lo (+ i 1)) (m (- (- j i) 1)) (val (ari i st))
                            (st (update-ari i (ari j st) st)))
                 (:instance update-ari-out-preserves-rng->
                            (lo (+ i 1)) (n (- (- j i) 1)) (x pivot) (m i) (val (ari j st)))))))

;; Extend a ">"-region by one good element at the top (no update).
(defthm rng->-extend
  (implies (and (rng-> lo m pivot st) (< pivot (ari (+ lo m) st)) (natp lo) (natp m))
           (rng-> lo (+ m 1) pivot st))
  :hints (("Goal" :induct (rng-> lo m pivot st)
           :expand ((rng-> lo (+ 1 m) pivot st) (rng-> lo 1 pivot st)))))

;; Right half of the Lomuto invariant: starting from a ">"-region [i, j),
;; positions [i', hi) end up > pivot (i' the returned boundary).
(defthm part-loop-right
  (implies (and (natp i) (natp j) (natp hi) (<= i j) (<= j hi)
                (rng-> i (- j i) pivot st)
                (natp k) (<= (mv-nth 0 (part-loop j i hi pivot st)) k) (< k hi))
           (< pivot (ari k (mv-nth 1 (part-loop j i hi pivot st)))))
  :hints (("Goal" :induct (part-loop j i hi pivot st)
           :do-not '(eliminate-destructors generalize)
           :in-theory (disable rng->-swap-step rng->-extend))
          ("Subgoal *1/3" :use ((:instance rng->-extend (lo i) (m (- j i)))))
          ("Subgoal *1/2" :use ((:instance rng->-swap-step)))
          ("Subgoal *1/1" :use ((:instance rng->-implies-ari (lo i) (n (- hi i)) (x pivot))))))

;; The partition pivot-split: a[p] = pivot, [lo,p) <= pivot, (p,hi] >= pivot.
(defthm partition-pivot
  (implies (and (natp lo) (natp hi) (<= lo hi))
           (equal (ari (mv-nth 0 (partition lo hi st)) (mv-nth 1 (partition lo hi st)))
                  (ari hi st)))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance ari-part-loop-out (j lo) (i lo) (pivot (ari hi st)) (k hi))
                 (:instance ari-swap
                            (i (mv-nth 0 (part-loop lo lo hi (ari hi st) st))) (j hi)
                            (k (mv-nth 0 (part-loop lo lo hi (ari hi st) st)))
                            (st (mv-nth 1 (part-loop lo lo hi (ari hi st) st))))))))

(defthm partition-left
  (implies (and (natp lo) (natp hi) (<= lo hi) (natp k)
                (<= lo k) (< k (mv-nth 0 (partition lo hi st))))
           (<= (ari k (mv-nth 1 (partition lo hi st))) (ari hi st)))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance part-loop-left (j lo) (i lo) (pivot (ari hi st)))
                 (:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st)))
                 (:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance ari-swap
                            (i (mv-nth 0 (part-loop lo lo hi (ari hi st) st))) (j hi) (k k)
                            (st (mv-nth 1 (part-loop lo lo hi (ari hi st) st))))))))

(defthm partition-right
  (implies (and (natp lo) (natp hi) (<= lo hi) (natp k)
                (< (mv-nth 0 (partition lo hi st)) k) (<= k hi))
           (<= (ari hi st) (ari k (mv-nth 1 (partition lo hi st)))))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance part-loop-right (j lo) (i lo) (pivot (ari hi st)) (k k))
                 (:instance part-loop-right (j lo) (i lo) (pivot (ari hi st))
                            (k (mv-nth 0 (part-loop lo lo hi (ari hi st) st))))
                 (:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st)))
                 (:instance part-loop-i-lower (j lo) (i lo) (pivot (ari hi st)))
                 (:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance ari-swap
                            (i (mv-nth 0 (part-loop lo lo hi (ari hi st) st))) (j hi) (k k)
                            (st (mv-nth 1 (part-loop lo lo hi (ari hi st) st))))))))

;; partition / qsort leave positions outside [lo, hi] unchanged.
(defthm ari-partition-out
  (implies (and (natp lo) (natp hi) (<= lo hi) (natp k) (or (< k lo) (< hi k)))
           (equal (ari k (mv-nth 1 (partition lo hi st))) (ari k st)))
  :hints (("Goal" :do-not-induct t :in-theory (enable partition)
           :use ((:instance ari-part-loop-out (j lo) (i lo) (pivot (ari hi st)) (k k))
                 (:instance part-loop-i-upper (j lo) (i lo) (pivot (ari hi st)))
                 (:instance part-loop-i-lower (j lo) (i lo) (pivot (ari hi st)))
                 (:instance natp-part-loop-i (j lo) (i lo) (pivot (ari hi st)))
                 (:instance ari-swap
                            (i (mv-nth 0 (part-loop lo lo hi (ari hi st) st))) (j hi) (k k)
                            (st (mv-nth 1 (part-loop lo lo hi (ari hi st) st))))))))

(defthm ari-qsort-out
  (implies (and (natp lo) (natp hi) (natp k) (or (< k lo) (< hi k)))
           (equal (ari k (qsort lo hi st)) (ari k st)))
  :hints (("Goal" :induct (qsort lo hi st) :in-theory (disable partition))
          ("Subgoal *1/2" :use ((:instance partition-lo) (:instance partition-hi)
                                (:instance natp-partition-i)))))

;; A pick-a-point ("bad-guy") bridge from pointwise bounds to the rng-<= /
;; rng->= predicates: the first index in [lo,lo+n) that violates the bound.
(defun rng-<=-bad (lo n x st)
  (declare (xargs :stobjs st :measure (nfix n) :verify-guards nil))
  (if (zp n) lo (if (< x (ari lo st)) lo (rng-<=-bad (+ lo 1) (- n 1) x st))))

(defun rng->=-bad (lo n x st)
  (declare (xargs :stobjs st :measure (nfix n) :verify-guards nil))
  (if (zp n) lo (if (< (ari lo st) x) lo (rng->=-bad (+ lo 1) (- n 1) x st))))

(defthm rng-<=-bad-bound
  (implies (and (natp lo) (natp n))
           (and (<= lo (rng-<=-bad lo n x st))
                (<= (rng-<=-bad lo n x st) (+ lo n))))
  :hints (("Goal" :induct (rng-<=-bad lo n x st))) :rule-classes :linear)

(defthm rng->=-bad-bound
  (implies (and (natp lo) (natp n))
           (and (<= lo (rng->=-bad lo n x st))
                (<= (rng->=-bad lo n x st) (+ lo n))))
  :hints (("Goal" :induct (rng->=-bad lo n x st))) :rule-classes :linear)

(defthm natp-rng-<=-bad
  (implies (natp lo) (natp (rng-<=-bad lo n x st)))
  :hints (("Goal" :induct (rng-<=-bad lo n x st))) :rule-classes :type-prescription)

(defthm natp-rng->=-bad
  (implies (natp lo) (natp (rng->=-bad lo n x st)))
  :hints (("Goal" :induct (rng->=-bad lo n x st))) :rule-classes :type-prescription)

(defthm rng-<=-suff
  (implies (<= (ari (rng-<=-bad lo n x st) st) x)
           (rng-<= lo n x st))
  :hints (("Goal" :induct (rng-<=-bad lo n x st))))

(defthm rng->=-suff
  (implies (<= x (ari (rng->=-bad lo n x st) st))
           (rng->= lo n x st))
  :hints (("Goal" :induct (rng->=-bad lo n x st))))

;; If the bad-guy scanned to the end, no violation exists.
(defthm rng-<=-bad-end
  (implies (and (natp lo) (natp n) (equal (rng-<=-bad lo n x st) (+ lo n)))
           (rng-<= lo n x st))
  :hints (("Goal" :induct (rng-<=-bad lo n x st))))

(defthm rng->=-bad-end
  (implies (and (natp lo) (natp n) (equal (rng->=-bad lo n x st) (+ lo n)))
           (rng->= lo n x st))
  :hints (("Goal" :induct (rng->=-bad lo n x st))))

;; The pivot-split as range predicates (consumed by qsort's preservation lemmas).
(defthm partition-left-rng
  (implies (and (natp lo) (natp hi) (<= lo hi))
           (rng-<= lo (- (mv-nth 0 (partition lo hi st)) lo)
                   (ari hi st) (mv-nth 1 (partition lo hi st))))
  :hints (("Goal" :do-not-induct t
           :use ((:instance rng-<=-suff (lo lo) (n (- (mv-nth 0 (partition lo hi st)) lo))
                            (x (ari hi st)) (st (mv-nth 1 (partition lo hi st))))
                 (:instance partition-left
                            (k (rng-<=-bad lo (- (mv-nth 0 (partition lo hi st)) lo)
                                           (ari hi st) (mv-nth 1 (partition lo hi st)))))
                 (:instance partition-pivot)
                 (:instance rng-<=-bad-bound (lo lo) (n (- (mv-nth 0 (partition lo hi st)) lo))
                            (x (ari hi st)) (st (mv-nth 1 (partition lo hi st))))
                 (:instance natp-rng-<=-bad (lo lo) (n (- (mv-nth 0 (partition lo hi st)) lo))
                            (x (ari hi st)) (st (mv-nth 1 (partition lo hi st))))
                 (:instance partition-lo) (:instance natp-partition-i)))))

(defthm partition-right-rng
  (implies (and (natp lo) (natp hi) (<= lo hi))
           (rng->= (+ (mv-nth 0 (partition lo hi st)) 1)
                   (- hi (mv-nth 0 (partition lo hi st)))
                   (ari hi st) (mv-nth 1 (partition lo hi st))))
  :hints (("Goal" :do-not-induct t
           :use ((:instance rng->=-suff (lo (+ (mv-nth 0 (partition lo hi st)) 1))
                            (n (- hi (mv-nth 0 (partition lo hi st))))
                            (x (ari hi st)) (st (mv-nth 1 (partition lo hi st))))
                 (:instance rng->=-bad-end (lo (+ (mv-nth 0 (partition lo hi st)) 1))
                            (n (- hi (mv-nth 0 (partition lo hi st))))
                            (x (ari hi st)) (st (mv-nth 1 (partition lo hi st))))
                 (:instance partition-right
                            (k (rng->=-bad (+ (mv-nth 0 (partition lo hi st)) 1)
                                           (- hi (mv-nth 0 (partition lo hi st)))
                                           (ari hi st) (mv-nth 1 (partition lo hi st)))))
                 (:instance rng->=-bad-bound (lo (+ (mv-nth 0 (partition lo hi st)) 1))
                            (n (- hi (mv-nth 0 (partition lo hi st))))
                            (x (ari hi st)) (st (mv-nth 1 (partition lo hi st))))
                 (:instance natp-rng->=-bad (lo (+ (mv-nth 0 (partition lo hi st)) 1))
                            (n (- hi (mv-nth 0 (partition lo hi st))))
                            (x (ari hi st)) (st (mv-nth 1 (partition lo hi st))))
                 (:instance partition-lo) (:instance partition-hi) (:instance natp-partition-i)))))

;; qsort preserves a bound on a range disjoint from (below / above) its
;; operating range.
(defthm qsort-below-rng-<=
  (implies (and (rng-<= a m x st) (natp a) (natp m) (natp lo) (natp hi) (<= (+ a m) lo))
           (rng-<= a m x (qsort lo hi st)))
  :hints (("Goal" :do-not-induct t
           :use ((:instance rng-<=-suff (lo a) (n m) (x x) (st (qsort lo hi st)))
                 (:instance ari-qsort-out (k (rng-<=-bad a m x (qsort lo hi st))))
                 (:instance rng-<=-implies-ari (lo a) (n m) (x x)
                            (k (rng-<=-bad a m x (qsort lo hi st))) (st st))
                 (:instance rng-<=-bad-bound (lo a) (n m) (x x) (st (qsort lo hi st)))
                 (:instance natp-rng-<=-bad (lo a) (n m) (x x) (st (qsort lo hi st)))))))

(defthm qsort-above-rng->=
  (implies (and (rng->= a m x st) (natp a) (natp m) (natp lo) (natp hi) (< hi a))
           (rng->= a m x (qsort lo hi st)))
  :hints (("Goal" :do-not-induct t
           :use ((:instance rng->=-suff (lo a) (n m) (x x) (st (qsort lo hi st)))
                 (:instance ari-qsort-out (k (rng->=-bad a m x (qsort lo hi st))))
                 (:instance rng->=-implies-ari (lo a) (n m) (x x)
                            (k (rng->=-bad a m x (qsort lo hi st))) (st st))
                 (:instance rng->=-bad-bound (lo a) (n m) (x x) (st (qsort lo hi st)))
                 (:instance natp-rng->=-bad (lo a) (n m) (x x) (st (qsort lo hi st)))))))

;; Linear forms of the extractors so the junction bounds feed linear arithmetic.
(defthm rng-<=-ari-linear
  (implies (and (rng-<= lo n x st) (natp lo) (natp n) (natp k) (<= lo k) (< k (+ lo n)))
           (<= (ari k st) x))
  :hints (("Goal" :use rng-<=-implies-ari)) :rule-classes :linear)

(defthm rng->=-ari-linear
  (implies (and (rng->= lo n x st) (natp lo) (natp n) (natp k) (<= lo k) (< k (+ lo n)))
           (<= x (ari k st)))
  :hints (("Goal" :use rng->=-implies-ari)) :rule-classes :linear)

;; "Non-decreasing over [lo, lo+n)".
(defun rng-ordered (lo n st)
  (declare (xargs :stobjs st :measure (nfix n) :verify-guards nil))
  (if (or (zp n) (zp (- n 1))) t
    (and (<= (ari lo st) (ari (+ lo 1) st))
         (rng-ordered (+ lo 1) (- n 1) st))))

;; Two adjacent ordered ranges with left <= mid <= right concatenate to ordered.
(defthm rng-ordered-append
  (implies (and (rng-ordered lo n1 st)
                (rng-ordered (+ lo n1) n2 st)
                (rng-<= lo n1 mid st)
                (rng->= (+ lo n1) n2 mid st)
                (natp lo) (natp n1) (natp n2))
           (rng-ordered lo (+ n1 n2) st))
  :hints (("Goal" :induct (rng-<= lo n1 mid st)
           :in-theory (disable |(< x (if a b c))| |(< (if a b c) x)|
                               default-less-than-1 default-less-than-2
                               simplify-products-gather-exponents-<))
          ("Subgoal *1/2" :expand ((rng-ordered lo (+ n1 n2) st)
                                   (rng-ordered lo n1 st)
                                   (rng-<= lo n1 mid st)))
          ("Subgoal *1/1" :expand ((rng-ordered lo (+ n1 n2) st)))))

;; The final qsort result: [lo,p) <= pivot, (p,hi] >= pivot, and a[p] = pivot.
(defthm qsort-keeps-left-<=
  (implies (and (natp lo) (natp hi) (< hi (ar-length st)) (< lo hi))
           (rng-<= lo (- (mv-nth 0 (partition lo hi st)) lo)
                   (ari hi st) (qsort lo hi st)))
  :hints (("Goal" :do-not-induct t :expand ((qsort lo hi st))
           :in-theory (disable partition)
           :use ((:instance partition-lo) (:instance partition-hi) (:instance natp-partition-i)
                 (:instance partition-left-rng)
                 (:instance qsort-preserves-rng-<=
                            (a lo) (m (- (mv-nth 0 (partition lo hi st)) lo)) (x (ari hi st))
                            (lo lo) (hi (- (mv-nth 0 (partition lo hi st)) 1))
                            (st (mv-nth 1 (partition lo hi st))))
                 (:instance qsort-below-rng-<=
                            (a lo) (m (- (mv-nth 0 (partition lo hi st)) lo)) (x (ari hi st))
                            (lo (+ (mv-nth 0 (partition lo hi st)) 1)) (hi hi)
                            (st (qsort lo (- (mv-nth 0 (partition lo hi st)) 1)
                                       (mv-nth 1 (partition lo hi st)))))))))

(defthm qsort-keeps-right->=
  (implies (and (natp lo) (natp hi) (< hi (ar-length st)) (< lo hi))
           (rng->= (+ (mv-nth 0 (partition lo hi st)) 1)
                   (- hi (mv-nth 0 (partition lo hi st)))
                   (ari hi st) (qsort lo hi st)))
  :hints (("Goal" :do-not-induct t :expand ((qsort lo hi st))
           :in-theory (disable partition)
           :use ((:instance partition-lo) (:instance partition-hi) (:instance natp-partition-i)
                 (:instance partition-right-rng)
                 (:instance qsort-above-rng->=
                            (a (+ (mv-nth 0 (partition lo hi st)) 1)) (m (- hi (mv-nth 0 (partition lo hi st)))) (x (ari hi st))
                            (lo lo) (hi (- (mv-nth 0 (partition lo hi st)) 1))
                            (st (mv-nth 1 (partition lo hi st))))
                 (:instance qsort-preserves-rng->=
                            (a (+ (mv-nth 0 (partition lo hi st)) 1)) (m (- hi (mv-nth 0 (partition lo hi st)))) (x (ari hi st))
                            (lo (+ (mv-nth 0 (partition lo hi st)) 1)) (hi hi)
                            (st (qsort lo (- (mv-nth 0 (partition lo hi st)) 1) (mv-nth 1 (partition lo hi st)))))))))

(defthm qsort-keeps-pivot
  (implies (and (natp lo) (natp hi) (< hi (ar-length st)) (< lo hi))
           (equal (ari (mv-nth 0 (partition lo hi st)) (qsort lo hi st))
                  (ari hi st)))
  :hints (("Goal" :do-not-induct t :expand ((qsort lo hi st))
           :in-theory (disable partition)
           :use ((:instance partition-lo) (:instance partition-hi) (:instance natp-partition-i)
                 (:instance partition-pivot)
                 (:instance ari-qsort-out
                            (lo lo) (hi (- (mv-nth 0 (partition lo hi st)) 1))
                            (k (mv-nth 0 (partition lo hi st)))
                            (st (mv-nth 1 (partition lo hi st))))
                 (:instance ari-qsort-out
                            (lo (+ (mv-nth 0 (partition lo hi st)) 1)) (hi hi)
                            (k (mv-nth 0 (partition lo hi st)))
                            (st (qsort lo (- (mv-nth 0 (partition lo hi st)) 1)
                                       (mv-nth 1 (partition lo hi st)))))))))

;; qsort accesses are rational (kills numberp case-splits in the ordering proof).
(defthm rationalp-ari-qsort
  (implies (and (stp st) (natp k) (< k (ar-length st)))
           (rationalp (ari k (qsort lo hi st))))
  :hints (("Goal" :use ((:instance rationalp-ari (i k) (st (qsort lo hi st)))
                        (:instance stp-qsort) (:instance ar-length-qsort)))))

(defthm rationalp-ari-qsort-tp
  (implies (and (stp st) (natp k) (< k (ar-length st)))
           (rationalp (ari k (qsort lo hi st))))
  :rule-classes :type-prescription
  :hints (("Goal" :use rationalp-ari-qsort)))

;; Consecutive elements of the qsort result are ordered: within-subrange pairs
;; come from the induction hypotheses, the two pivot junctions from the
;; keeps-left / keeps-right / keeps-pivot facts.
(defthm qsort-ordered
  (implies (and (stp st) (natp lo) (natp hi) (< hi (ar-length st)) (natp k) (<= lo k) (< k hi))
           (<= (ari k (qsort lo hi st)) (ari (+ k 1) (qsort lo hi st))))
  :hints (("Goal" :induct (qsort lo hi st) :in-theory (disable partition))
          ("Subgoal *1/2"
           :use ((:instance partition-lo) (:instance partition-hi) (:instance natp-partition-i)
                 (:instance qsort-keeps-left-<=) (:instance qsort-keeps-right->=)
                 (:instance qsort-keeps-pivot)
                 (:instance rng-<=-implies-ari
                            (lo lo) (n (- (mv-nth 0 (partition lo hi st)) lo))
                            (x (ari hi st)) (k k) (st (qsort lo hi st)))
                 (:instance rng->=-implies-ari
                            (lo (+ (mv-nth 0 (partition lo hi st)) 1))
                            (n (- hi (mv-nth 0 (partition lo hi st))))
                            (x (ari hi st)) (k (+ k 1)) (st (qsort lo hi st)))
                 (:instance ari-qsort-out
                            (lo (+ (mv-nth 0 (partition lo hi st)) 1)) (hi hi) (k k)
                            (st (qsort lo (- (mv-nth 0 (partition lo hi st)) 1)
                                       (mv-nth 1 (partition lo hi st)))))
                 (:instance ari-qsort-out
                            (lo (+ (mv-nth 0 (partition lo hi st)) 1)) (hi hi) (k (+ k 1))
                            (st (qsort lo (- (mv-nth 0 (partition lo hi st)) 1)
                                       (mv-nth 1 (partition lo hi st)))))))))

;; ===========================================================================
;; Top-level: sort the whole array in place, and the bad-guy bridge from
;; pointwise consecutive ordering to the RNG-ORDERED predicate.
;; ===========================================================================
(defun sort-array (st)
  (declare (xargs :stobjs st :guard (stp st)))   ; guards verified (qsort is)
  (qsort 0 (- (ar-length st) 1) st))

(defun ord-bad (lo n st)
  (declare (xargs :stobjs st :measure (nfix n) :verify-guards nil))
  (if (or (zp n) (zp (- n 1))) lo
    (if (< (ari (+ lo 1) st) (ari lo st)) lo
      (if (zp (- n 2)) lo
        (ord-bad (+ lo 1) (- n 1) st)))))

(defthm natp-ord-bad
  (implies (natp lo) (natp (ord-bad lo n st)))
  :hints (("Goal" :induct (ord-bad lo n st))) :rule-classes :type-prescription)

(defthm ord-bad-bound
  (implies (and (natp lo) (natp n) (< 1 n))
           (and (<= lo (ord-bad lo n st))
                (<= (ord-bad lo n st) (+ lo n -2))))
  :hints (("Goal" :induct (ord-bad lo n st))) :rule-classes :linear)

(defthm ord-suff
  (implies (<= (ari (ord-bad lo n st) st) (ari (+ (ord-bad lo n st) 1) st))
           (rng-ordered lo n st))
  :hints (("Goal" :induct (ord-bad lo n st))))

(defthm natp-ar-length
  (natp (ar-length st))
  :hints (("Goal" :in-theory (enable ar-length)))
  :rule-classes :type-prescription)

(defthm rng-ordered-small
  (implies (< n 2) (rng-ordered lo n st))
  :hints (("Goal" :expand ((rng-ordered lo n st)))))

;; Top-level sortedness.
(defthm sort-array-sorted
  (implies (stp st)
           (rng-ordered 0 (ar-length st) (sort-array st)))
  :hints (("Goal" :cases ((< (ar-length st) 2)) :in-theory (disable qsort))
          ("Subgoal 2"
           :use ((:instance ord-suff (lo 0) (n (ar-length st)) (st (sort-array st)))
                 (:instance qsort-ordered (lo 0) (hi (- (ar-length st) 1))
                            (k (ord-bad 0 (ar-length st) (sort-array st))))
                 (:instance ord-bad-bound (lo 0) (n (ar-length st)) (st (sort-array st)))))))

;; Top-level permutation / well-formedness / length.
(defthm sort-array-perm
  (perm (nth 0 (sort-array st)) (nth 0 st))
  :hints (("Goal" :in-theory (e/d (sort-array) (qsort))
           :use ((:instance perm-nth0-qsort (lo 0) (hi (- (ar-length st) 1)))))))

(defthm sort-array-stp
  (implies (stp st) (stp (sort-array st)))
  :hints (("Goal" :in-theory (e/d (sort-array) (qsort))
           :use ((:instance stp-qsort (lo 0) (hi (- (ar-length st) 1)))))))

(defthm sort-array-length
  (equal (ar-length (sort-array st)) (ar-length st))
  :hints (("Goal" :in-theory (e/d (sort-array) (qsort))
           :use ((:instance ar-length-qsort (lo 0) (hi (- (ar-length st) 1)))))))

;; ===========================================================================
;; FULL CORRECTNESS of the in-place quicksort SORT-ARRAY: the result is
;; non-decreasing, a permutation of the input, well-formed, and of equal length.
;; ===========================================================================
(defthm sort-array-correct
  (implies (stp st)
           (and (rng-ordered 0 (ar-length st) (sort-array st))        ; sorted
                (perm (nth 0 (sort-array st)) (nth 0 st))              ; permutation
                (stp (sort-array st))                                  ; well-formed
                (equal (ar-length (sort-array st)) (ar-length st))))   ; length preserved
  :hints (("Goal" :in-theory (disable sort-array)
           :use (sort-array-sorted sort-array-perm sort-array-stp sort-array-length))))
